---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Colbateries S.A. — Distribución y Comercialización',
  description = 'Distribuidor líder de relojería, baterías, y accesorios en la Zona Libre de Colón, Panamá.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Montserrat:wght@700;800;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* RESET Y BASES */
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    /* Paleta de Marca Colbateries */
    --blue: #024598;
    --red: #e64132;
    --yellow: #f2a900; /* Color Principal de Acento (Q&Q) */
    
    /* Escala de Blancos y Grises (Clean Look) */
    --white: #ffffff;
    --gray-50: #f9fafb;
    --gray-100: #f3f4f6;
    --gray-200: #e5e7eb;
    --gray-700: #374151;
    --gray-900: #111827;

    /* Tipografías */
    --font-heading: 'Montserrat', sans-serif;
    --font-body: 'Inter', sans-serif;

    /* Sombras más suaves para fondo blanco */
    --shadow-sm: 0 1px 2px rgba(0,0,0,0.05);
    --shadow-md: 0 4px 12px rgba(0,0,0,0.05);
    --shadow-lg: 0 10px 25px rgba(0,0,0,0.04);
    --shadow-yellow: 0 8px 24px rgba(242, 169, 0, 0.25);
    
    --transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--font-body);
    background-color: var(--white); /* Fondo Totalmente Blanco */
    color: var(--gray-900);
    line-height: 1.5;
    overflow-x: hidden;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 3rem;
  }

  @media (max-width: 768px) {
    .container { padding: 0 1.5rem; }
  }

  /* TIPOGRAFÍA GLOBAL */
  .section-tag {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--blue); /* Azul para etiquetas */
    margin-bottom: 0.75rem;
    border-left: 3px solid var(--yellow); /* Detalle amarillo */
    padding-left: 0.75rem;
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
    line-height: 1.1;
    color: var(--blue); /* Azul para elegancia en títulos */
    margin-bottom: 1.5rem;
  }

  .section-title span {
    color: var(--yellow); /* Amarillo para resaltar palabras clave */
  }

  .section-desc {
    font-size: 1.05rem;
    color: var(--gray-700);
    line-height: 1.7;
    max-width: 600px;
  }

  /* BOTONES (Ahora con el Amarillo de Q&Q) */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 2.25rem;
    background: var(--yellow);
    color: var(--gray-900); /* Texto oscuro sobre amarillo */
    font-weight: 700;
    font-size: 0.95rem;
    border-radius: 8px;
    transition: all var(--transition);
    box-shadow: var(--shadow-yellow);
    border: none;
    cursor: pointer;
  }

  .btn-primary:hover {
    background: #e09d00;
    transform: translateY(-2px);
    box-shadow: 0 12px 30px rgba(242, 169, 0, 0.35);
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 2.25rem;
    background: transparent;
    border: 2px solid var(--gray-200);
    color: var(--gray-700);
    font-weight: 700;
    border-radius: 8px;
    transition: all var(--transition);
  }

  .btn-outline:hover {
    border-color: var(--blue);
    color: var(--blue);
    background: var(--gray-50);
  }

  /* ANIMACIONES BÁSICAS */
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.8s ease-out;
  }

  .reveal.active {
    opacity: 1;
    transform: translateY(0);
  }

  /* Utility para secciones blancas con separadores sutiles */
  section {
    padding: 100px 0;
    background: var(--white);
  }

  .bg-light {
    background: var(--gray-50);
  }
</style>

<script>
  // Script para las animaciones al hacer scroll
  const observerOptions = {
    threshold: 0.1
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('active');
      }
    });
  }, observerOptions);

  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>
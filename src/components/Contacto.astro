---
---

<section class="contacto-section" id="contacto">
  <div class="container">
    <div class="contacto-grid">

      <!-- INFO LEFT -->
      <div class="contacto-info">
        <span class="section-tag reveal">Contacto</span>
        <h2 class="section-title reveal delay-100">
          Hablemos de<br/><span class="title-accent">su negocio</span>
        </h2>
        <p class="section-desc reveal delay-200">
          Cotizaciones rápidas por WhatsApp o formulario. Respondemos el mismo día.
        </p>

        <div class="contact-items">
          <a href="https://wa.me/50764156382" target="_blank" rel="noopener" class="contact-item reveal delay-200">
            <div class="contact-icon-wrap green">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <div class="contact-text">
              <p class="contact-label">WhatsApp</p>
              <p class="contact-value">+507 6415-6382</p>
            </div>
            <svg class="contact-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>

          <a href="tel:+5074411617" class="contact-item reveal delay-300">
            <div class="contact-icon-wrap blue">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.63A2 2 0 012.18 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 8.15a16 16 0 006.29 6.29l1.41-1.41a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
              </svg>
            </div>
            <div class="contact-text">
              <p class="contact-label">Teléfono</p>
              <p class="contact-value">441-1617 / 441-1614</p>
            </div>
          </a>

          <a href="mailto:colbateriespanamazl@hotmail.com" class="contact-item reveal delay-400">
            <div class="contact-icon-wrap yellow">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div class="contact-text">
              <p class="contact-label">Email</p>
              <p class="contact-value">colbateriespanamazl@hotmail.com</p>
            </div>
          </a>

          <div class="contact-item reveal delay-500">
            <div class="contact-icon-wrap gray">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div class="contact-text">
              <p class="contact-label">Dirección</p>
              <p class="contact-value">Manzana 28, Local 8A, Torre Cofrisa 9<br/>Zona Libre de Colón, Panamá</p>
            </div>
          </div>
        </div>

        <div class="social-links reveal delay-500">
          <a href="https://www.facebook.com/ColbatteriesPanama" target="_blank" rel="noopener" class="social-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
            </svg>
            Facebook
          </a>
          <a href="https://www.instagram.com/colbatteries_sa" target="_blank" rel="noopener" class="social-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
            Instagram
          </a>
        </div>
      </div>

      <!-- FORM RIGHT -->
      <div class="contacto-form-wrap reveal-right delay-200">
        <div class="form-card">
          <div class="form-header">
            <h3 class="form-title">Solicitar cotización</h3>
            <p class="form-subtitle">Le respondemos por email y WhatsApp</p>
          </div>

          <form class="contact-form" id="contactForm">
            <!-- Formspree hidden fields -->
            <input type="hidden" name="_subject" value="Nueva cotización - Colbateries S.A." />
            <input type="hidden" name="_next" value="/" />

            <div class="form-row">
              <div class="form-group float-group">
                <input type="text" id="nombre" name="nombre" placeholder=" " required autocomplete="name" />
                <label for="nombre">Nombre <span class="req">*</span></label>
              </div>
              <div class="form-group float-group">
                <input type="text" id="empresa" name="empresa" placeholder=" " autocomplete="organization" />
                <label for="empresa">Empresa</label>
              </div>
            </div>
            <div class="form-group float-group">
              <input type="email" id="email" name="email" placeholder=" " required autocomplete="email" />
              <label for="email">Correo electrónico <span class="req">*</span></label>
            </div>
            <div class="form-group float-group float-group--textarea">
              <textarea id="mensaje" name="mensaje" rows="4" placeholder=" " required></textarea>
              <label for="mensaje">Mensaje <span class="req">*</span></label>
            </div>

            <button type="submit" class="form-submit" id="submitBtn">
              <span class="btn-text">Enviar cotización</span>
              <svg class="btn-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </button>

            <div class="form-success" id="formSuccess" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
              Mensaje enviado. Le contactaremos pronto.
            </div>
          </form>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .contacto-section {
    padding: 7rem 0;
    background: var(--white);
  }

  .contacto-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  /* ── INFO ── */
  .section-title { margin-bottom: 1rem; }

  .title-accent {
    color: var(--yellow);
    position: relative;
    display: inline-block;
  }

  .title-accent::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0.05em;
    width: 100%;
    height: 0.06em;
    background: var(--yellow);
    opacity: 0.35;
    border-radius: 4px;
  }

  .contact-items {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin: 2rem 0;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.1rem;
    border-radius: 14px;
    border: 1.5px solid rgba(2, 29, 80, 0.07);
    background: rgba(2, 29, 80, 0.02);
    text-decoration: none;
    color: var(--blue);
    transition: border-color 0.25s ease, background 0.25s ease, transform 0.25s ease;
  }

  a.contact-item:hover {
    border-color: rgba(242, 169, 0, 0.5);
    background: rgba(242, 169, 0, 0.04);
    transform: translateX(4px);
  }

  .contact-icon-wrap {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .contact-icon-wrap.green  { background: rgba(37,211,102,0.1);  color: #1da851; }
  .contact-icon-wrap.blue   { background: rgba(2,29,80,0.08);    color: var(--blue); }
  .contact-icon-wrap.yellow { background: rgba(242,169,0,0.12);  color: #c88800; }
  .contact-icon-wrap.gray   { background: rgba(2,29,80,0.05);    color: rgba(2,29,80,0.5); }

  .contact-text { flex: 1; min-width: 0; }

  .contact-label {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(2, 29, 80, 0.4);
    margin-bottom: 0.15rem;
  }

  .contact-value {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--blue);
    line-height: 1.4;
  }

  .contact-arrow {
    color: rgba(2,29,80,0.25);
    transition: transform 0.2s ease, color 0.2s ease;
    flex-shrink: 0;
  }

  a.contact-item:hover .contact-arrow {
    transform: translateX(3px);
    color: var(--yellow);
  }

  .social-links {
    display: flex;
    gap: 0.6rem;
  }

  .social-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.55rem 1.1rem;
    border: 1.5px solid rgba(2, 29, 80, 0.12);
    border-radius: 100px;
    font-size: 0.82rem;
    font-weight: 600;
    color: rgba(2, 29, 80, 0.6);
    text-decoration: none;
    transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
  }

  .social-btn:hover {
    border-color: var(--blue);
    color: var(--blue);
    background: rgba(2,29,80,0.04);
  }

  /* ── FORM CARD ── */
  .form-card {
    background: var(--blue);
    border-radius: 24px;
    padding: 2.75rem;
    position: relative;
    overflow: hidden;
  }

  .form-card::before {
    content: '';
    position: absolute;
    top: -60px;
    right: -60px;
    width: 200px;
    height: 200px;
    border-radius: 50%;
    background: rgba(242,169,0,0.06);
    pointer-events: none;
  }

  .form-header { margin-bottom: 2rem; }

  .form-title {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 900;
    color: var(--white);
    margin-bottom: 0.35rem;
  }

  .form-subtitle {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.45);
    font-weight: 500;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    position: relative;
    z-index: 1;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  /* ── FLOATING LABEL ── */
  .form-group {
    position: relative;
  }

  .req { color: var(--yellow); }

  .float-group label {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 0.88rem;
    font-weight: 500;
    color: rgba(255,255,255,0.32);
    text-transform: none;
    letter-spacing: normal;
    pointer-events: none;
    transition:
      top 0.22s cubic-bezier(0.4,0,0.2,1),
      transform 0.22s cubic-bezier(0.4,0,0.2,1),
      font-size 0.22s cubic-bezier(0.4,0,0.2,1),
      color 0.22s,
      letter-spacing 0.22s,
      text-transform 0.22s;
    z-index: 1;
    background: transparent;
    padding: 0 0.25rem;
    white-space: nowrap;
  }

  /* Textarea: label starts at top, not center */
  .float-group--textarea label {
    top: 0.95rem;
    transform: none;
  }

  /* Floated: input has content or is focused */
  .float-group input:focus + label,
  .float-group input:not(:placeholder-shown) + label {
    top: -0.62rem;
    transform: none;
    font-size: 0.6rem;
    font-weight: 700;
    color: var(--yellow);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: var(--blue);
  }

  .float-group--textarea textarea:focus + label,
  .float-group--textarea textarea:not(:placeholder-shown) + label {
    top: -0.62rem;
    font-size: 0.6rem;
    font-weight: 700;
    color: var(--yellow);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: var(--blue);
  }

  .form-group input,
  .form-group textarea {
    background: rgba(255,255,255,0.06);
    border: 1.5px solid rgba(255,255,255,0.1);
    border-radius: 10px;
    padding: 0.9rem 1rem;
    color: var(--white);
    font-family: var(--font-body);
    font-size: 0.92rem;
    outline: none;
    transition: border-color 0.2s ease, background 0.2s ease, box-shadow 0.2s;
    resize: none;
    width: 100%;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    border-color: var(--yellow);
    background: rgba(255,255,255,0.09);
    box-shadow: 0 0 0 3px rgba(242,169,0,0.12);
  }

  .form-submit {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    width: 100%;
    padding: 0.95rem 1.5rem;
    background: var(--yellow);
    color: var(--blue);
    font-family: var(--font-heading);
    font-size: 0.92rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    border: none;
    border-radius: 100px;
    cursor: pointer;
    margin-top: 0.5rem;
    transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.25s ease;
  }

  .form-submit:hover {
    background: #ffbe0b;
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(242,169,0,0.4);
  }

  .form-submit:active { transform: translateY(0); }

  .form-submit.loading {
    opacity: 0.7;
    pointer-events: none;
  }

  .form-success {
    display: none;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border-radius: 12px;
    background: rgba(37, 211, 102, 0.12);
    border: 1px solid rgba(37, 211, 102, 0.3);
    color: #4ade80;
    font-size: 0.9rem;
    font-weight: 600;
    margin-top: 0.5rem;
  }

  .form-success.visible { display: flex; }

  @media (max-width: 900px) {
    .contacto-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  @media (max-width: 560px) {
    .form-row { grid-template-columns: 1fr; }
    .form-card { padding: 2rem 1.5rem; }
  }
</style>

<script>
  const FORMSPREE_ID = 'YOUR_FORM_ID'; // Reemplazar con tu ID de Formspree

  const form = document.getElementById('contactForm') as HTMLFormElement;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
  const successMsg = document.getElementById('formSuccess') as HTMLDivElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const nombre  = (form.elements.namedItem('nombre')  as HTMLInputElement).value.trim();
    const empresa = (form.elements.namedItem('empresa') as HTMLInputElement).value.trim();
    const email   = (form.elements.namedItem('email')   as HTMLInputElement).value.trim();
    const mensaje = (form.elements.namedItem('mensaje') as HTMLTextAreaElement).value.trim();

    submitBtn.classList.add('loading');
    submitBtn.querySelector('.btn-text')!.textContent = 'Enviando…';

    let emailSent = false;

    // 1. Enviar por email via Formspree
    if (FORMSPREE_ID !== 'YOUR_FORM_ID') {
      try {
        const res = await fetch(`https://formspree.io/f/${FORMSPREE_ID}`, {
          method: 'POST',
          headers: { 'Accept': 'application/json', 'Content-Type': 'application/json' },
          body: JSON.stringify({ nombre, empresa, email, mensaje }),
        });
        emailSent = res.ok;
      } catch (_) {}
    }

    // 2. Abrir WhatsApp con el mensaje
    const waText = encodeURIComponent(
      `Hola Colbateries, soy ${nombre}${empresa ? ` de ${empresa}` : ''}.\n\nMi correo: ${email}\n\n${mensaje}`
    );
    window.open(`https://wa.me/50764156382?text=${waText}`, '_blank');

    // 3. Mostrar confirmación
    submitBtn.style.display = 'none';
    successMsg.classList.add('visible');
    form.reset();
  });
</script>

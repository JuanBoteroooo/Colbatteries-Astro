---
const stats = [
  { num: '+20',    label: 'años en el mercado',      target: 20,   prefix: '+', suffix: '',   comma: false },
  { num: '+1,500', label: 'referencias en stock',    target: 1500, prefix: '+', suffix: '',   comma: true  },
  { num: '2do',   label: 'hub comercial del mundo',  target: 2,    prefix: '',  suffix: 'do', comma: false },
];
---

<section class="nosotros-section" id="nosotros">
  <div class="container nosotros-grid">

    <!-- VISUAL LEFT -->
    <div class="nosotros-visual reveal-left">
      <div class="stat-wall">
        {stats.map((s, i) => (
          <div class={`stat-block stat-${i} reveal delay-${i * 100}`}>
            <span class="stat-num" data-target={s.target} data-prefix={s.prefix} data-suffix={s.suffix} data-comma={String(s.comma)}>{s.num}</span>
            <span class="stat-label">{s.label}</span>
          </div>
        ))}
        <div class="stat-badge reveal delay-300">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          Zona Libre de Colón, Panamá
        </div>
      </div>
      <div class="visual-deco"></div>
    </div>

    <!-- TEXT RIGHT -->
    <div class="nosotros-text">
      <span class="section-tag reveal">Nosotros</span>
      <h2 class="section-title reveal delay-100">
        Su socio de confianza en <span class="title-accent">distribución</span>
      </h2>
      <p class="section-desc reveal delay-200">
        Colbateries S.A. es una empresa distribuidora especializada en productos de relojería y pilas, ubicada estratégicamente en la Zona Libre de Colón, Panamá — el segundo centro comercial libre más grande del mundo.
      </p>
      <p class="section-desc reveal delay-300">
        Ofrecemos un portafolio de más de 1,500 productos de las marcas más reconocidas a nivel mundial, con soporte directo por WhatsApp y atención personalizada para distribuidores y comercios.
      </p>

      <ul class="nosotros-features">
        {[
          'Stock disponible e inmediato',
          'Envíos internacionales',
          'Atención directa por WhatsApp',
          'Precios competitivos para distribuidores',
        ].map((f, i) => (
          <li class={`feature-item reveal delay-${(i + 3) * 100}`}>
            <span class="feature-check">
              <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="2 6 5 9 10 3"/>
              </svg>
            </span>
            {f}
          </li>
        ))}
      </ul>

      <div class="brands-strip reveal delay-500">
        {['Miyota', 'ETA', 'Ronda', 'Renata', 'GP', 'Maxell', 'Polemik'].map(b => (
          <span class="brand-tag">{b}</span>
        ))}
      </div>

      <a href="https://wa.me/50764156382" target="_blank" rel="noopener" class="btn-primary reveal delay-700">
        Contactar ahora
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<style>
  .nosotros-section {
    padding: 7rem 0;
    background: var(--white);
    overflow: hidden;
  }

  .nosotros-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  /* ── VISUAL ── */
  .nosotros-visual {
    position: relative;
  }

  .stat-wall {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    position: relative;
    z-index: 1;
  }

  .stat-block {
    background: var(--blue);
    border-radius: 20px;
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    position: relative;
    overflow: hidden;
    transition: transform 0.35s ease, box-shadow 0.35s ease;
  }

  .stat-block:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 50px rgba(2, 29, 80, 0.2);
  }

  .stat-block::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(242,169,0,0.08) 0%, transparent 60%);
    pointer-events: none;
  }

  /* span first stat full-width */
  .stat-0 { grid-column: 1 / -1; background: var(--blue); }
  .stat-1 { background: #F2A900; }
  .stat-2 { background: #0a2d6e; }

  .stat-num {
    font-family: var(--font-heading);
    font-size: clamp(2.8rem, 5vw, 4rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--white);
  }

  .stat-1 .stat-num { color: var(--blue); }

  .stat-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: rgba(255,255,255,0.55);
    line-height: 1.35;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .stat-1 .stat-label { color: rgba(2,29,80,0.6); }

  /* location badge */
  .stat-badge {
    grid-column: 1 / -1;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.9rem 1.25rem;
    border-radius: 100px;
    border: 1.5px solid rgba(2, 29, 80, 0.12);
    background: rgba(2, 29, 80, 0.03);
    font-size: 0.82rem;
    font-weight: 600;
    color: rgba(2, 29, 80, 0.6);
    letter-spacing: 0.02em;
  }

  .stat-badge svg { color: var(--blue); flex-shrink: 0; }

  /* decorative blob */
  .visual-deco {
    position: absolute;
    width: 340px;
    height: 340px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(242,169,0,0.12) 0%, transparent 70%);
    top: -60px;
    right: -80px;
    pointer-events: none;
    z-index: 0;
  }

  /* ── TEXT ── */
  .nosotros-text {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .nosotros-text .section-title {
    margin-bottom: 1.5rem;
  }

  .title-accent {
    color: var(--yellow);
    position: relative;
    display: inline-block;
  }

  .title-accent::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0.05em;
    width: 100%;
    height: 0.06em;
    background: var(--yellow);
    border-radius: 4px;
    opacity: 0.35;
  }

  .nosotros-features {
    list-style: none;
    margin: 2rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    font-size: 0.95rem;
    font-weight: 500;
    color: rgba(2, 29, 80, 0.75);
  }

  .feature-check {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--blue);
    color: var(--yellow);
    flex-shrink: 0;
  }

  /* ── BRANDS STRIP ── */
  .brands-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-bottom: 1.75rem;
  }

  .brand-tag {
    font-family: var(--font-heading);
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(2,29,80,0.4);
    border: 1.5px solid rgba(2,29,80,0.1);
    border-radius: 100px;
    padding: 0.28rem 0.7rem;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
    cursor: default;
  }

  .brand-tag:hover {
    color: var(--blue);
    border-color: rgba(242,169,0,0.45);
    background: rgba(242,169,0,0.05);
  }

  @media (max-width: 900px) {
    .nosotros-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
</style>

<script>
  function easeOutCubic(t: number) { return 1 - Math.pow(1 - t, 3); }

  function fmt(n: number, comma: boolean): string {
    if (!comma) return String(n);
    return n >= 1000
      ? Math.floor(n / 1000) + ',' + String(n % 1000).padStart(3, '0')
      : String(n);
  }

  function animateCount(el: HTMLElement) {
    const target   = parseInt(el.dataset.target!);
    const prefix   = el.dataset.prefix ?? '';
    const suffix   = el.dataset.suffix ?? '';
    const comma    = el.dataset.comma === 'true';
    const duration = 1200;
    const start    = performance.now();

    function tick(now: number) {
      const progress = Math.min((now - start) / duration, 1);
      const value    = Math.round(easeOutCubic(progress) * target);
      el.textContent = prefix + fmt(value, comma) + suffix;
      if (progress < 1) requestAnimationFrame(tick);
    }

    requestAnimationFrame(tick);
  }

  const statNums = document.querySelectorAll<HTMLElement>('.stat-num[data-target]');

  const countObs = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        animateCount(entry.target as HTMLElement);
        countObs.unobserve(entry.target);
      }
    });
  }, { threshold: 0.55 });

  statNums.forEach(el => countObs.observe(el));
</script>

---
---

<section class="nosotros-section" id="nosotros">
  <div class="container nosotros-grid">
    <div class="nosotros-visual reveal-left">
      <div class="visual-card main-card">
        <div class="card-icon">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
        </div>
        <p class="card-title">Relojería de precisión</p>
        <p class="card-sub">Movimientos, piezas y herramientas para profesionales</p>
      </div>
      <div class="visual-card accent-card reveal-left delay-200">
        <div class="card-icon orange">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
        </div>
        <p class="card-title">Zona Libre de Colón</p>
        <p class="card-sub">Manzana 28, Local 8A, Torre Cofrisa 9</p>
      </div>
      <div class="bg-decoration"></div>
    </div>

    <div class="nosotros-text">
      <span class="section-tag reveal">Nosotros</span>
      <h2 class="section-title reveal delay-100">Su socio de confianza en <span>distribución</span></h2>
      <p class="section-desc reveal delay-200">
        Colbateries S.A. es una empresa distribuidora especializada en productos de relojería y pilas, ubicada estratégicamente en la Zona Libre de Colón, Panamá — el segundo centro comercial libre más grande del mundo.
      </p>
      <p class="section-desc reveal delay-300" style="margin-top: 1rem;">
        Ofrecemos un portafolio de más de 1,500 productos de las marcas más reconocidas a nivel mundial, con soporte directo por WhatsApp y atención personalizada para distribuidores y comercios.
      </p>

      <div class="nosotros-features">
        {[
          { icon: '✓', text: 'Stock disponible inmediato' },
          { icon: '✓', text: 'Envíos internacionales' },
          { icon: '✓', text: 'Atención por WhatsApp' },
          { icon: '✓', text: 'Precios competitivos para distribuidores' },
        ].map((f, i) => (
          <div class={`feature-item reveal delay-${(i + 2) * 100}`}>
            <span class="feature-icon">{f.icon}</span>
            <span>{f.text}</span>
          </div>
        ))}
      </div>

      <a href="https://wa.me/50764156382" target="_blank" rel="noopener" class="btn-primary reveal delay-500">
        Contactar ahora
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .nosotros-section {
    padding: 7rem 0;
    background: var(--white);
  }

  .nosotros-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .nosotros-visual {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    min-height: 380px;
  }

  .visual-card {
    background: var(--gray-100);
    border-radius: 16px;
    padding: 2rem 1.5rem;
    border: 1px solid var(--gray-200);
    transition: transform var(--transition), box-shadow var(--transition);
  }

  .visual-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-md);
  }

  .main-card {
    grid-column: 1 / -1;
    background: var(--blue);
    border-color: transparent;
  }

  .main-card .card-title {
    color: var(--white);
  }

  .main-card .card-sub {
    color: rgba(255,255,255,0.6);
  }

  .main-card .card-icon {
    color: var(--red);
  }

  .accent-card {
    grid-column: 1 / -1;
    background: var(--white);
    border-color: var(--gray-200);
    box-shadow: var(--shadow-md);
  }

  .card-icon {
    color: var(--blue);
    margin-bottom: 1rem;
  }

  .card-icon.orange {
    color: var(--red);
  }

  .card-title {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--blue);
    margin-bottom: 0.4rem;
  }

  .card-sub {
    font-size: 0.875rem;
    color: var(--gray-400);
    line-height: 1.5;
  }

  .bg-decoration {
    position: absolute;
    top: -20px;
    left: -20px;
    right: -20px;
    bottom: -20px;
    background: radial-gradient(circle at 20% 80%, rgba(2, 69, 152, 0.05), transparent 60%);
    pointer-events: none;
    z-index: -1;
    border-radius: 24px;
  }

  .nosotros-text {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .nosotros-text .section-title {
    margin-bottom: 1.5rem;
  }

  .nosotros-text .section-desc + .section-desc {
    margin-top: 0;
  }

  .nosotros-features {
    margin: 2rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.95rem;
    color: var(--gray-700);
    font-weight: 500;
  }

  .feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    background: var(--red);
    color: var(--white);
    border-radius: 50%;
    font-size: 0.7rem;
    font-weight: 900;
    flex-shrink: 0;
  }

  @media (max-width: 900px) {
    .nosotros-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .nosotros-visual {
      min-height: auto;
    }
  }
</style>

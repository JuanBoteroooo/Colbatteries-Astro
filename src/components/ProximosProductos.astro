---
const products = [
  { img: '/images/proximos/polemik-gold-chrono.jpg',      name: 'Cronógrafo Dorado',    sub: 'Colección Premium' },
  { img: '/images/proximos/polemik-sport-crono.jpg',      name: 'Sport Chronograph',    sub: 'Colección Sport'   },
  { img: '/images/proximos/polemik-dual-time-gold.jpg',   name: 'Dual Time Digital',    sub: 'Colección Digital' },
  { img: '/images/proximos/polemik-tachymetre-negro.jpg', name: 'Tachymetre Sport',     sub: 'Colección Sport'   },
  { img: '/images/proximos/polemik-nautilus-negro.jpg',   name: 'Nautilus Black',       sub: 'Colección Clásica' },
  { img: '/images/proximos/polemik-silver-chrono.jpg',    name: 'Cronógrafo Plateado',  sub: 'Colección Premium' },
  { img: '/images/proximos/polemik-tonneau-gold.jpg',     name: 'Tonneau WR30M',        sub: 'Colección Sport'   },
  { img: '/images/proximos/polemik-digital-gold.jpg',     name: 'Digital Dorado',       sub: 'Colección Digital' },
  { img: '/images/proximos/polemik-digital-silver.jpg',   name: 'Digital Plateado',     sub: 'Colección Digital' },
  { img: '/images/proximos/polemik-lady-ceramic.jpg',     name: 'Lady Cerámico',        sub: 'Colección Dama'    },
  { img: '/images/proximos/polemik-wheel-sport.jpg',      name: 'Wheel Sport',          sub: 'Edición Especial'  },
];
---

<section class="proximos-section" id="proximos">

  <div class="container proximos-header reveal">
    <span class="proximos-tag">
      <span class="tag-dot"></span>
      Próximamente
    </span>
    <h2 class="proximos-title">Nueva colección <span class="title-accent">Polemik</span></h2>
    <p class="proximos-sub">11 nuevos modelos exclusivos para mayoristas</p>
  </div>

  <div class="carousel-scene" id="carouselScene">
    <div class="carousel-stage" id="carouselStage">
      {products.map((p, i) => (
        <div class="c-card" data-index={i}>
          <div class="c-watch-wrap">
            <div class="c-glow" aria-hidden="true"></div>
            <img src={p.img} alt={p.name} class="c-img" loading="lazy" />
            <div class="c-oval-shadow" aria-hidden="true"></div>
          </div>
          <div class="c-info">
            <p class="c-sub">{p.sub}</p>
            <h3 class="c-name">{p.name}</h3>
          </div>
        </div>
      ))}
    </div>

    <button class="c-arrow c-arrow--prev" id="prevBtn" aria-label="Anterior">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
    </button>
    <button class="c-arrow c-arrow--next" id="nextBtn" aria-label="Siguiente">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </button>
  </div>

  <div class="c-dots" id="cDots">
    {products.map((_, i) => (
      <button class="c-dot" data-dot={i} aria-label={`Producto ${i + 1}`}></button>
    ))}
  </div>

  <div class="proximos-footer reveal">
    <a href="https://wa.me/50764156382" target="_blank" rel="noopener" class="proximos-wa">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      Consultar disponibilidad
    </a>
  </div>
</section>

<style>
  /* ── SECTION ── */
  .proximos-section {
    padding: 7rem 0 5rem;
    background: var(--white);
    position: relative;
    overflow: hidden;
    border-top: 1px solid var(--gray-200);
  }

  /* ── HEADER ── */
  .proximos-header {
    text-align: center;
    margin-bottom: 1rem;
    position: relative;
    z-index: 1;
  }

  .proximos-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--blue);
    background: rgba(2,29,80,0.05);
    border: 1px solid rgba(2,29,80,0.12);
    padding: 0.38rem 1rem;
    border-radius: 100px;
    margin-bottom: 1.25rem;
  }

  .tag-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--yellow);
    flex-shrink: 0;
    box-shadow: 0 0 6px var(--yellow);
    animation: dotPulse 2s ease-in-out infinite;
  }

  @keyframes dotPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(242,169,0,0.6); }
    50%       { box-shadow: 0 0 0 5px rgba(242,169,0,0); }
  }

  .proximos-title {
    font-family: var(--font-heading);
    font-size: clamp(2.4rem, 5vw, 4rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--blue);
    margin-bottom: 0.9rem;
  }

  .title-accent { color: var(--yellow); }

  .proximos-sub {
    font-size: 1rem;
    color: rgba(2,29,80,0.4);
    font-weight: 500;
  }

  /* ── CAROUSEL SCENE ── */
  .carousel-scene {
    position: relative;
    width: 100%;
    height: 580px;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
    overflow: visible;
  }

  .carousel-stage {
    position: relative;
    width: 100%;
    height: 100%;
  }

  /* ── CARD ── */
  .c-card {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 340px;
    display: flex;
    flex-direction: column;
    align-items: center;
    cursor: pointer;
    transition:
      transform 0.65s cubic-bezier(0.22, 1, 0.36, 1),
      opacity   0.65s cubic-bezier(0.22, 1, 0.36, 1);

    /* hidden default */
    transform: translate(-50%, -50%) scale(0.4);
    opacity: 0;
    pointer-events: none;
    z-index: 0;
  }

  /* Active */
  .c-card.is-active {
    transform: translate(-50%, -50%) scale(1);
    opacity: 1;
    pointer-events: auto;
    z-index: 3;
  }

  /* Sides */
  .c-card.is-prev {
    transform: translate(calc(-50% - 310px), -50%) scale(0.72);
    opacity: 0.5;
    pointer-events: auto;
    z-index: 2;
  }
  .c-card.is-next {
    transform: translate(calc(-50% + 310px), -50%) scale(0.72);
    opacity: 0.5;
    pointer-events: auto;
    z-index: 2;
  }

  /* Far sides */
  .c-card.is-prev2 {
    transform: translate(calc(-50% - 490px), -50%) scale(0.5);
    opacity: 0.18;
    pointer-events: none;
    z-index: 1;
  }
  .c-card.is-next2 {
    transform: translate(calc(-50% + 490px), -50%) scale(0.5);
    opacity: 0.18;
    pointer-events: none;
    z-index: 1;
  }

  /* ── WATCH WRAP ── */
  .c-watch-wrap {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Blue glow reflection — appears on hover */
  .c-glow {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    width: 75%;
    height: 120px;
    border-radius: 50%;
    background: radial-gradient(ellipse at center, rgba(2,69,152,0.22) 0%, transparent 70%);
    filter: blur(22px);
    opacity: 0;
    transition: opacity 0.5s ease;
    z-index: 0;
    pointer-events: none;
  }

  .c-card.is-active:hover .c-glow { opacity: 1; }

  /* Watch image */
  .c-img {
    width: 100%;
    height: 360px;
    object-fit: contain;
    display: block;
    position: relative;
    z-index: 1;
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* Float animation — only active card */
  .c-card.is-active .c-img {
    animation: watchFloat 4.5s ease-in-out infinite;
  }

  @keyframes watchFloat {
    0%, 100% { transform: translateY(0px);    }
    50%       { transform: translateY(-16px);  }
  }

  /* Pause float on hover so glow stays aligned */
  .c-card.is-active:hover .c-img {
    animation-play-state: paused;
    transform: translateY(-8px) scale(1.03);
  }

  /* Oval shadow under watch */
  .c-oval-shadow {
    width: 55%;
    height: 18px;
    border-radius: 50%;
    background: radial-gradient(ellipse, rgba(2,29,80,0.12) 0%, transparent 70%);
    margin-top: -8px;
    position: relative;
    z-index: 0;
    transition: transform 0.5s ease, opacity 0.5s ease;
  }

  .c-card.is-active .c-oval-shadow {
    animation: shadowPulse 4.5s ease-in-out infinite;
  }

  @keyframes shadowPulse {
    0%, 100% { transform: scaleX(1);    opacity: 0.8; }
    50%       { transform: scaleX(0.78); opacity: 0.4; }
  }

  .c-card.is-active:hover .c-oval-shadow {
    animation-play-state: paused;
    transform: scaleX(0.85);
    opacity: 0.5;
  }

  /* ── INFO ── */
  .c-info {
    text-align: center;
    margin-top: 1.25rem;
  }

  .c-sub {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(2,29,80,0.3);
    margin-bottom: 0.3rem;
  }

  .c-name {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 900;
    color: var(--blue);
    letter-spacing: -0.02em;
    transition: color 0.25s;
  }

  .c-card.is-active:hover .c-name { color: #024598; }

  /* ── ARROWS ── */
  .c-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1.5px solid rgba(2,29,80,0.12);
    background: var(--white);
    color: rgba(2,29,80,0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 10;
    transition: border-color 0.2s, background 0.2s, color 0.2s, box-shadow 0.25s, transform 0.2s;
    box-shadow: 0 2px 12px rgba(2,29,80,0.06);
  }

  .c-arrow:hover {
    border-color: var(--blue);
    background: var(--blue);
    color: var(--white);
    transform: translateY(-50%) scale(1.08);
    box-shadow: 0 4px 20px rgba(2,29,80,0.2);
  }

  .c-arrow--prev { left: calc(50% - 260px); }
  .c-arrow--next { right: calc(50% - 260px); }

  /* ── DOTS ── */
  .c-dots {
    display: flex;
    justify-content: center;
    gap: 0.45rem;
    margin-top: 0.5rem;
    position: relative;
    z-index: 1;
  }

  .c-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    border: none;
    background: rgba(2,29,80,0.15);
    cursor: pointer;
    transition: background 0.25s, width 0.3s, border-radius 0.3s;
    padding: 0;
  }

  .c-dot.is-active {
    background: var(--blue);
    width: 20px;
    border-radius: 100px;
  }

  /* ── CTA ── */
  .proximos-footer {
    text-align: center;
    margin-top: 2.5rem;
    position: relative;
    z-index: 1;
  }

  .proximos-wa {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.7rem 1.6rem;
    background: transparent;
    border: 1.5px solid #25D366;
    color: #1a9e4e;
    font-size: 0.85rem;
    font-weight: 700;
    border-radius: 100px;
    text-decoration: none;
    transition: background 0.2s, color 0.2s, box-shadow 0.25s;
  }

  .proximos-wa:hover {
    background: #25D366;
    color: var(--white);
    box-shadow: 0 4px 20px rgba(37,211,102,0.3);
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .carousel-scene { height: 520px; }

    .c-card.is-prev {
      transform: translate(calc(-50% - 220px), -50%) scale(0.65);
    }
    .c-card.is-next {
      transform: translate(calc(-50% + 220px), -50%) scale(0.65);
    }
    .c-card.is-prev2, .c-card.is-next2 { opacity: 0; }

    .c-arrow--prev { left: 0.75rem; }
    .c-arrow--next { right: 0.75rem; }
  }

  @media (max-width: 560px) {
    .carousel-scene { height: 460px; }
    .c-card { width: 260px; }
    .c-img { height: 280px; }

    .c-card.is-prev {
      transform: translate(calc(-50% - 160px), -50%) scale(0.6);
      opacity: 0.3;
    }
    .c-card.is-next {
      transform: translate(calc(-50% + 160px), -50%) scale(0.6);
      opacity: 0.3;
    }

    .c-arrow--prev { left: 0.25rem; }
    .c-arrow--next { right: 0.25rem; }
  }
</style>

<script>
  const TOTAL = 11;
  const INTERVAL = 3800;

  let current = 0;
  let timer: ReturnType<typeof setInterval>;

  const cards = document.querySelectorAll<HTMLElement>('.c-card');
  const dots  = document.querySelectorAll<HTMLElement>('.c-dot');

  function mod(n: number, m: number) { return ((n % m) + m) % m; }

  function update() {
    cards.forEach((card, i) => {
      card.classList.remove('is-active', 'is-prev', 'is-next', 'is-prev2', 'is-next2');
      const diff = mod(i - current, TOTAL);
      if      (diff === 0)         card.classList.add('is-active');
      else if (diff === 1)         card.classList.add('is-next');
      else if (diff === TOTAL - 1) card.classList.add('is-prev');
      else if (diff === 2)         card.classList.add('is-next2');
      else if (diff === TOTAL - 2) card.classList.add('is-prev2');
    });
    dots.forEach((dot, i) => dot.classList.toggle('is-active', i === current));
  }

  function next() { current = mod(current + 1, TOTAL); update(); }
  function prev() { current = mod(current - 1, TOTAL); update(); }

  function startAuto() {
    clearInterval(timer);
    timer = setInterval(next, INTERVAL);
  }

  document.getElementById('nextBtn')?.addEventListener('click', () => { next(); startAuto(); });
  document.getElementById('prevBtn')?.addEventListener('click', () => { prev(); startAuto(); });

  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      current = parseInt(dot.dataset.dot!);
      update();
      startAuto();
    });
  });

  cards.forEach(card => {
    card.addEventListener('click', () => {
      const idx = parseInt(card.dataset.index!);
      if      (idx === mod(current + 1, TOTAL)) { next(); startAuto(); }
      else if (idx === mod(current - 1, TOTAL)) { prev(); startAuto(); }
    });
  });

  update();
  startAuto();
</script>

---
const pathname = Astro.url.pathname;
const isHome = pathname === '/';

const links = [
  { href: '/', label: 'Inicio' },
  { href: '/catalogo', label: 'Catálogo' },
  { href: '/contacto', label: 'Contacto' },
  { href: '/nosotros', label: 'Nosotros' },
];
---

<nav class="navbar" id="navbar">
  <div class="container navbar-inner">
    <a href="/" class="logo">
      <img src="/logo.jpeg" alt="Colbateries S.A." class="logo-img" />
    </a>

    <button class="hamburger" id="hamburger" aria-label="Abrir menú">
      <span></span><span></span><span></span>
    </button>

    <ul class="nav-links" id="navLinks">
      {links.map(l => (
        <li>
          <a
            href={l.href}
            class={`nav-link${pathname === l.href ? ' active' : ''}`}
          >
            {l.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="https://wa.me/50764156382"
          target="_blank"
          rel="noopener"
          class="nav-cta"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Cotizar
        </a>
      </li>
    </ul>
  </div>
</nav>

<style>
  .navbar {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 1000;
    transition: all var(--transition);
    padding: 1rem 0;
    /* Ahora la barra siempre es blanca por el diseño clean */
    background: var(--white);
    border-bottom: 1px solid var(--gray-100);
  }

  .navbar.scrolled {
    padding: 0.8rem 0;
    box-shadow: var(--shadow-sm);
  }

  .navbar-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    text-decoration: none;
    display: flex;
    align-items: center;
  }

  .logo-img {
    height: 58px;
    width: auto;
    display: block;
    object-fit: contain;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
    list-style: none;
  }

  .nav-link {
    text-decoration: none;
    color: var(--gray-900); /* Textos oscuros para contrastar con blanco */
    font-weight: 600;
    font-size: 0.95rem;
    transition: color var(--transition);
    position: relative;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--yellow); /* Línea amarilla al pasar el mouse */
    transition: width var(--transition);
  }

  .nav-link:hover::after,
  .nav-link.active::after {
    width: 100%;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--yellow);
  }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1.25rem;
    background: var(--yellow); /* Botón principal Amarillo */
    color: var(--gray-900); /* Texto negro para contraste */
    font-weight: 700;
    font-size: 0.9rem;
    border-radius: 6px;
    text-decoration: none;
    transition: all var(--transition);
    box-shadow: var(--shadow-yellow);
  }

  .nav-cta:hover {
    background: #e09d00;
    transform: translateY(-2px);
  }

  /* Hamburger Menu */
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    z-index: 1001;
  }

  .hamburger span {
    width: 24px;
    height: 2px;
    background: var(--gray-900);
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  @media (max-width: 768px) {
    .hamburger { display: flex; }

    .nav-links {
      position: fixed;
      top: 0;
      right: -100%;
      width: 280px;
      height: 100vh;
      background: var(--white); /* Menú móvil ahora es blanco, no azul */
      flex-direction: column;
      align-items: flex-start;
      padding: 6rem 2rem 2rem;
      gap: 1.5rem;
      transition: right 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: -4px 0 24px rgba(0,0,0,0.1);
      border-left: 4px solid var(--yellow); /* Detalle amarillo en el borde */
    }

    .nav-links.open { right: 0; }
    
    .nav-link { 
      font-size: 1.1rem; 
    }

    /* Animación del icono de hamburguesa al abrir */
    .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .hamburger.open span:nth-child(2) { opacity: 0; }
    .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
  }
</style>

<script>
  const navbar = document.getElementById('navbar');
  const hamburger = document.getElementById('hamburger');
  const navLinks = document.getElementById('navLinks');

  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('scrolled', window.scrollY > 20);
  });

  hamburger?.addEventListener('click', () => {
    navLinks?.classList.toggle('open');
    hamburger?.classList.toggle('open');
  });

  // Cerrar menú al hacer click en un enlace (ideal para móviles)
  document.querySelectorAll('.nav-link').forEach(link => {
    link.addEventListener('click', () => {
      navLinks?.classList.remove('open');
      hamburger?.classList.remove('open');
    });
  });
</script>
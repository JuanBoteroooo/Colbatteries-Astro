---
const reasons = [
  {
    num: '01',
    title: 'Stock inmediato',
    desc: 'Más de 1,500 referencias disponibles para entrega inmediata. Sin esperas, sin sorpresas.',
  },
  {
    num: '02',
    title: 'Precios competitivos',
    desc: 'Ubicados en la Zona Libre de Colón, ofrecemos precios de distribuidor directamente a su negocio.',
  },
  {
    num: '03',
    title: 'Soporte directo',
    desc: 'Atención personalizada por WhatsApp. Hable con una persona real que conoce los productos.',
  },
  {
    num: '04',
    title: 'Envíos internacionales',
    desc: 'Despachamos a toda Latinoamérica y el Caribe. Consulte disponibilidad y costos.',
  },
];
---

<section class="porque-section">
  <div class="container">
    <div class="porque-header">
      <span class="section-tag reveal">¿Por qué elegirnos?</span>
      <h2 class="section-title reveal delay-100">La diferencia <span>Colbateries</span></h2>
    </div>

    <div class="reasons-grid">
      {reasons.map((r, i) => (
        <div class={`reason-card reveal delay-${i * 100 + 100}`}>
          <span class="reason-num">{r.num}</span>
          <h3 class="reason-title">{r.title}</h3>
          <p class="reason-desc">{r.desc}</p>
        </div>
      ))}
    </div>

    <div class="porque-banner reveal delay-400">
      <div class="banner-text">
        <h3 class="banner-big">¿Listo para abastecer su inventario?</h3>
        <p class="banner-sub">Únase a la red de distribuidores de Q&Q y más marcas líderes.</p>
      </div>
      <a href="https://wa.me/50764156382" target="_blank" rel="noopener" class="btn-primary-red-accent">
        Solicitar Lista de Precios
      </a>
    </div>
  </div>
</section>

<style>
  .porque-section {
    /* Base Inamovible: Blanco */
    background: var(--white);
    padding: 6rem 0;
  }

  .porque-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .reasons-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 2.5rem;
    margin-bottom: 5rem;
  }

  .reason-card {
    background: var(--white);
    padding: 2rem;
    border-radius: 16px;
    border: 1px solid var(--gray-100);
    transition: all var(--transition);
    /* 1er lugar sutil: Sombra amarilla al inicio */
    box-shadow: 0 4px 15px rgba(242, 169, 0, 0.05);
  }

  .reason-card:hover {
    /* 1er lugar fuerte: Borde amarillo al pasar el mouse */
    border-color: var(--yellow);
    transform: translateY(-5px);
    box-shadow: var(--shadow-yellow);
  }

  .reason-num {
    display: block;
    font-family: var(--font-heading);
    font-size: 3rem;
    font-weight: 900;
    /* 1er lugar: El amarillo se lleva la mirada inicial */
    color: var(--yellow);
    line-height: 1;
    margin-bottom: 1rem;
  }

  .reason-title {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 800;
    /* 2do lugar: Azul para la seriedad de la razón */
    color: var(--blue);
    margin-bottom: 0.75rem;
  }

  .reason-desc {
    font-size: 0.9rem;
    color: var(--gray-700);
    line-height: 1.65;
  }

  /* REDISEÑO DEL BANNER: De azul pesado a Blanco luminoso con marco amarillo */
  .porque-banner {
    background: var(--white);
    border-radius: 20px;
    padding: 3rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    /* 1er lugar: Borde grueso amarillo */
    border: 4px solid var(--yellow);
    box-shadow: var(--shadow-yellow);
  }

  .banner-text {
    flex: 1;
  }

  .banner-big {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 900;
    /* 2do lugar: Azul para la lectura del banner */
    color: var(--blue);
    margin-bottom: 0.5rem;
  }

  .banner-sub {
    font-size: 1.1rem;
    color: var(--gray-700);
  }

  /* Botón con el detalle del 3er Lugar (Rojo) */
  .btn-primary-red-accent {
    display: inline-flex;
    align-items: center;
    padding: 1rem 2rem;
    background: var(--yellow); /* Botón amarillo */
    color: var(--gray-900);
    font-weight: 800;
    border-radius: 8px;
    text-decoration: none;
    transition: all var(--transition);
    /* 3er lugar: Borde inferior rojo como detalle de acento */
    border-bottom: 4px solid var(--red);
  }

  .btn-primary-red-accent:hover {
    background: #e09d00;
    transform: translateY(2px);
    border-bottom-width: 2px; /* Efecto de que se presiona el botón */
  }

  @media (max-width: 768px) {
    .porque-banner {
      flex-direction: column;
      text-align: center;
      padding: 2rem;
    }
    .banner-big { font-size: 1.6rem; }
  }
</style>
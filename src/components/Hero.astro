---
---

<section class="hero" id="inicio">

  <div class="hero-bg">
    <div class="hero-dots"></div>
    <div class="hero-glow"></div>
  </div>

  <div class="container hero-content">

    <!-- LEFT: text -->
    <div class="hero-text">

      <div class="hero-eyebrow fade-up">
        <span class="eyebrow-rule"></span>
        <svg class="eyebrow-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
        <p>Zona Libre de Colón · Panamá</p>
      </div>

      <h1 class="hero-title fade-up delay-1">
        Tu aliado mayorista en
        <span class="hero-highlight">Relojería</span>
        y accesorios
      </h1>

      <p class="hero-desc fade-up delay-2">
        Distribución exclusiva de las mejores marcas de relojería e insumos. Más de 1,500 referencias en stock para despacho inmediato a toda América.
      </p>

      <div class="hero-actions fade-up delay-3">
        <a href="#categorias" class="btn-primary-yellow">
          Explorar Catálogo
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
        <a href="https://wa.me/50764156382" target="_blank" rel="noopener" class="btn-outline-blue">
          Contactar Ventas
        </a>
      </div>

      <div class="hero-stats fade-up delay-4">
        <div class="stat-item">
          <span class="stat-num">+15</span>
          <span class="stat-label">Años en relojería</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-num">1,500</span>
          <span class="stat-label">Referencias en stock</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-num">24h</span>
          <span class="stat-label">Despacho a América</span>
        </div>
      </div>

    </div>

    <!-- RIGHT: visual -->
    <div class="hero-visual fade-in delay-2">

      <!-- Watchmaking dial accent — the defining detail -->
      <div class="dial-ring" aria-hidden="true">
        <span class="dial-tick t12"></span>
        <span class="dial-tick t3"></span>
        <span class="dial-tick t6"></span>
        <span class="dial-tick t9"></span>
      </div>

      <!-- Image frame -->
      <div class="image-frame">
        <img
          src="https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=900&auto=format&fit=crop&q=85"
          alt="Relojería mayorista Colbateries"
          class="hero-img"
        />
        <div class="image-shine"></div>
      </div>

      <!-- Floating credential card -->
      <div class="float-card">
        <div class="float-card-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
        </div>
        <div class="float-card-body">
          <span class="float-card-tag">Distribuidor Oficial</span>
          <p class="float-card-brand">Baterias Q&Q</p>
        </div>
        <div class="float-card-stars">
          {Array.from({length: 5}).map(() => (
            <svg width="10" height="10" viewBox="0 0 24 24" fill="var(--yellow)"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          ))}
        </div>
      </div>

      <!-- Top-right stock badge -->
      <div class="stock-badge">
        <span class="stock-dot"></span>
        Stock disponible
      </div>

    </div>
  </div>
</section>

<style>
  /* ── BASE ── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 120px 0 80px;
    background: var(--white);
    overflow: hidden;
    z-index: 1;
  }

  /* ── BACKGROUND ── */
  .hero-bg { position: absolute; inset: 0; z-index: 0; pointer-events: none; }

  .hero-dots {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(2,69,152,0.055) 1px, transparent 1px);
    background-size: 28px 28px;
  }

  .hero-glow {
    position: absolute;
    top: -20%;
    right: -5%;
    width: 680px;
    height: 680px;
    background: radial-gradient(circle, rgba(242,169,0,0.08) 0%, transparent 60%);
    filter: blur(70px);
  }

  /* ── LAYOUT ── */
  .hero-content {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 4rem;
    align-items: center;
    width: 100%;
  }

  /* ── LEFT: TEXT ── */
  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1.75rem;
  }

  .eyebrow-rule {
    width: 28px;
    height: 2.5px;
    background: var(--red);
    border-radius: 2px;
    flex-shrink: 0;
  }

  .eyebrow-icon {
    color: var(--blue);
    opacity: 0.5;
    flex-shrink: 0;
  }

  .hero-eyebrow p {
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--blue);
    opacity: 0.65;
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(2.6rem, 4.8vw, 4.2rem);
    font-weight: 900;
    line-height: 1.08;
    color: var(--blue);
    margin-bottom: 1.5rem;
    letter-spacing: -0.025em;
  }

  .hero-highlight {
    color: var(--yellow);
    position: relative;
    display: inline-block;
  }

  .hero-highlight::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 0;
    width: 100%;
    height: 10px;
    background: rgba(242,169,0,0.18);
    z-index: -1;
    border-radius: 2px;
  }

  .hero-desc {
    font-size: 1.1rem;
    color: var(--gray-700);
    max-width: 500px;
    margin-bottom: 2.5rem;
    line-height: 1.75;
  }

  /* ── CTAs ── */
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    margin-bottom: 3.5rem;
  }

  .btn-primary-yellow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.875rem;
    background: var(--yellow);
    color: var(--gray-900);
    font-weight: 800;
    font-size: 0.95rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.25s, transform 0.25s, box-shadow 0.25s;
    box-shadow: 0 6px 22px rgba(242,169,0,0.3);
  }

  .btn-primary-yellow:hover {
    background: #e09d00;
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(242,169,0,0.38);
  }

  .btn-outline-blue {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 1.875rem;
    background: transparent;
    border: 2px solid var(--blue);
    color: var(--blue);
    font-weight: 700;
    font-size: 0.95rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.25s, color 0.25s;
  }

  .btn-outline-blue:hover { background: var(--blue); color: var(--white); }

  /* ── STATS ── */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .stat-item { display: flex; flex-direction: column; gap: 0.2rem; }

  .stat-num {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 900;
    color: var(--yellow);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .stat-label {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--blue);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 0.6;
  }

  .stat-divider {
    width: 1px;
    height: 42px;
    background: var(--gray-200);
    flex-shrink: 0;
  }

  /* ── RIGHT: VISUAL ── */
  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* Watch dial ring — the watchmaking signature detail */
  .dial-ring {
    position: absolute;
    width: 108%;
    aspect-ratio: 1 / 1;
    border-radius: 50%;
    border: 1.5px solid rgba(242,169,0,0.2);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 0;
    pointer-events: none;
  }

  /* Tick marks at 12, 3, 6, 9 */
  .dial-tick {
    position: absolute;
    background: rgba(242,169,0,0.45);
    border-radius: 1px;
  }

  .t12, .t6 { width: 2px; height: 10px; left: calc(50% - 1px); }
  .t3, .t9  { width: 10px; height: 2px; top: calc(50% - 1px); }

  .t12 { top: 0; }
  .t6  { bottom: 0; }
  .t3  { right: 0; }
  .t9  { left: 0; }

  /* Image frame */
  .image-frame {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 460px;
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid rgba(2,69,152,0.08);
    box-shadow:
      0 4px 6px rgba(0,0,0,0.03),
      0 12px 40px rgba(0,0,0,0.09),
      0 30px 60px rgba(0,0,0,0.06);
  }

  .hero-img {
    width: 100%;
    height: 520px;
    object-fit: cover;
    display: block;
    transition: transform 0.8s ease;
  }

  .hero-visual:hover .hero-img { transform: scale(1.03); }

  /* Subtle top-down shine overlay */
  .image-shine {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(255,255,255,0.06) 0%,
      transparent 40%,
      rgba(0,0,0,0.04) 100%
    );
    pointer-events: none;
  }

  /* ── FLOATING CREDENTIAL CARD ── */
  .float-card {
    position: absolute;
    bottom: 2.5rem;
    left: -2rem;
    z-index: 3;
    background: var(--white);
    padding: 1rem 1.25rem;
    border-radius: 14px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.12), 0 2px 6px rgba(0,0,0,0.05);
    border-left: 3px solid var(--blue);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    animation: floatY 6s ease-in-out infinite;
    min-width: 190px;
  }

  .float-card-icon {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(2,69,152,0.07);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--blue);
    flex-shrink: 0;
  }

  .float-card-body { flex: 1; }

  .float-card-tag {
    display: block;
    font-size: 0.6rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--blue);
    opacity: 0.55;
    margin-bottom: 0.2rem;
  }

  .float-card-brand {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 900;
    color: var(--blue);
    line-height: 1.1;
  }

  .float-card-stars {
    display: flex;
    gap: 1px;
    flex-shrink: 0;
    align-self: flex-end;
    padding-bottom: 2px;
  }

  /* ── STOCK BADGE ── */
  .stock-badge {
    position: absolute;
    top: 1.5rem;
    right: -1rem;
    z-index: 3;
    background: var(--white);
    padding: 0.45rem 0.9rem;
    border-radius: 20px;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--blue);
    box-shadow: 0 4px 16px rgba(0,0,0,0.1);
    display: flex;
    align-items: center;
    gap: 0.45rem;
    letter-spacing: 0.01em;
    animation: floatY 6s ease-in-out infinite;
    animation-delay: 1s;
  }

  .stock-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 6px rgba(34,197,94,0.6);
    flex-shrink: 0;
    animation: pulseDot 2s ease-in-out infinite;
  }

  @keyframes floatY {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-8px); }
  }

  @keyframes pulseDot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.6; transform: scale(0.85); }
  }

  /* ── ENTRY ANIMATIONS ── */
  .fade-up {
    opacity: 0;
    transform: translateY(22px);
    animation: fadeUp 0.75s forwards;
  }

  .fade-in {
    opacity: 0;
    animation: fadeIn 0.9s forwards;
  }

  .delay-1 { animation-delay: 0.12s; }
  .delay-2 { animation-delay: 0.28s; }
  .delay-3 { animation-delay: 0.46s; }
  .delay-4 { animation-delay: 0.64s; }

  @keyframes fadeUp {
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeIn {
    to { opacity: 1; }
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 992px) {
    .hero { padding: 110px 0 60px; min-height: auto; }

    .hero-content {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 3.5rem;
    }

    .hero-eyebrow  { justify-content: center; }
    .hero-desc     { margin-inline: auto; }
    .hero-actions  { justify-content: center; }
    .hero-stats    { justify-content: center; }

    .hero-visual   { max-width: 420px; margin: 0 auto; }

    .hero-img      { height: 400px; }

    .float-card {
      left: 0.5rem;
      bottom: -1.5rem;
      animation: none;
    }

    .stock-badge { right: 0.5rem; animation: none; }
  }

  @media (max-width: 560px) {
    .hero-img  { height: 320px; }
    .stat-num  { font-size: 1.65rem; }
    .hero-stats { gap: 1.25rem; }
  }
</style>

  'CABALLERO':        'badge-cab',
  'DAMA':             'badge-dama',
  'CON ROSCA':        'badge-rosca',
  'CON ROSCA Y TUBO': 'badge-tubo',
  'ECONÓMICAS':       'badge-eco',
  'DIGITAL':          'badge-digital',
  'ACCESORIO':        'badge-acc',
  'PLANO':            'badge-vidrio-plano',
  'LUPA':             'badge-vidrio-lupa',
  'ZAFIRADO':         'badge-vidrio-zaf',
  'ESPECIAL':         'badge-vidrio-esp',
  'PEGANTE':          'badge-vidrio-peg',
  'ACRILICO':         'badge-vidrio-acr',
  'CONCAVO':          'badge-vidrio-plano',
  'LAMINA':           'badge-vidrio-plano',
  'DOMO':             'badge-vidrio-lupa',
  'OTRO':             'badge-acc',

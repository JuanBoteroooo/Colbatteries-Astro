  'CABALLERO':        'Caballero',
  'DAMA':             'Dama',
  'CON ROSCA':        'Con Rosca',
  'CON ROSCA Y TUBO': 'Rosca y Tubo',
  'ECONÓMICAS':       'Económica',
  'DIGITAL':          'Digital',
  'ACCESORIO':        'Accesorio',
  'SALTO':            'Salto',
  'PENDULO':          'Péndulo',
  'MUSICAL':          'Musical',
  'FUERZA':           'Fuerza',
  'EMPOTRABLE':       'Empotrable',

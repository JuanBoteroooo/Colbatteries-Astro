  'TERMINALES':       'badge-ins-ter',
  'TIJAS':            'badge-ins-tij',
  'CORONAS':          'badge-ins-cor',
  'REPUESTOS':        'badge-ins-rep',
  'OTROS':            'badge-acc',
  'TAPADORA':         'badge-her-tap',
  'DESTAPADORA':      'badge-her-des',
  'PINZA':            'badge-her-pin',
  'DESTORNILLADOR':   'badge-her-dst',
  'MAQUINA':          'badge-her-maq',

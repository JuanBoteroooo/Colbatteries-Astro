---
interface Detalles {
  dimensiones?:  string;
  altura?:       string;
  joyas?:        number;
  bateria?:      string;
  placas?:       string;
  intercambios?: string;
}

interface Props {
  imagenSrc:          string;
  imagenCatalogoSrc:  string;
  titulo:             string;
  detalles:           Detalles;
  tipo?:              string;
  fecha?:             boolean;
  isCorona?:          boolean;
  isWatch?:           boolean;
  isVidrios?:         boolean;
  isModulos?:         boolean;
  isInsumos?:         boolean;
  isHerramientas?:    boolean;
  isJoyeria?:         boolean;
  isGorras?:          boolean;
  rosca?:             string;
  medida?:            string;
  color?:             string;
  grosor?:            string;
  forma?:             string;
  nombre?:            string;
  marca?:             string;
  especificacion?:    string;
}

const {
  imagenSrc, imagenCatalogoSrc, titulo, detalles,
  tipo, fecha,
  isCorona = false, isWatch = false, isVidrios = false, isModulos = false, isInsumos = false, isHerramientas = false, isJoyeria = false, isGorras = false,
  rosca, medida, color, grosor, forma, nombre, marca, especificacion,
} = Astro.props;

const BADGE_CLASS: Record<string, string> = {

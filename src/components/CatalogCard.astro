---
interface Detalles {
  tipo?:         string;
  dimensiones?:  string;
  altura?:       string;
  joyas?:        number;
  bateria?:      string;
  placas?:       string;
  intercambios?: string;
}

interface Props {
  imagenSrc:         string;
  titulo:            string;   // "ETA 251.262"
  descripcionCorta?: string;
  detalles:          Detalles;
  tipo?:             string;
  fecha?:            boolean;
}

const { imagenSrc, titulo, detalles, tipo, fecha } = Astro.props;

const spaceIdx = titulo.indexOf(' ');
const prefix   = spaceIdx > -1 ? titulo.slice(0, spaceIdx)  : '';
const modelNum = spaceIdx > -1 ? titulo.slice(spaceIdx + 1) : titulo;

const BADGE_CLASS: Record<string, string> = {
  'CRONÓGRAFO': 'badge-crono',
  'CABALLERO':  'badge-cab',
  'DAMA':       'badge-dama',
};

const TIPO_LABEL: Record<string, string> = {
  'CRONÓGRAFO': 'Cronógrafo',
  'CABALLERO':  'Caballero',
  'DAMA':       'Dama',
};

type SpecItem = { k: string; v: string };

const specs: SpecItem[] = [
  detalles.dimensiones             ? { k: 'Dimensiones', v: detalles.dimensiones }    : null,
  detalles.altura                  ? { k: 'Altura',      v: `${detalles.altura}mm` }  : null,
  (detalles.joyas != null)         ? { k: 'Joyas',       v: String(detalles.joyas) }  : null,
  detalles.bateria                 ? { k: 'Batería',     v: `CR ${detalles.bateria}` }: null,
].filter((s): s is SpecItem => s !== null).slice(0, 4);

const waModel  = encodeURIComponent(`Hola, me interesa información sobre el movimiento ${titulo}`);
const waHref   = `https://wa.me/50764156382?text=${waModel}`;
---

<article class="cc">
  <!-- Image zone -->
  <div class="cc-img-zone">
    <img
      src={imagenSrc}
      alt={titulo}
      class="cc-img"
      loading="lazy"
      decoding="async"
    />
    <!-- Badges -->
    <div class="cc-badge-strip">
      {tipo && (
        <span class={`cc-badge ${BADGE_CLASS[tipo] ?? 'badge-cab'}`}>
          {TIPO_LABEL[tipo] ?? tipo}
        </span>
      )}
      {fecha && <span class="cc-badge badge-fecha">+ Fecha</span>}
    </div>
  </div>

  <!-- Info zone -->
  <div class="cc-body">
    <div class="cc-header">
      {prefix && <span class="cc-prefix">{prefix}</span>}
      <h3 class="cc-modelo">{modelNum}</h3>
    </div>

    {specs.length > 0 && (
      <div class="cc-rule"></div>
      <dl class="cc-specs">
        {specs.map(s => (
          <div class="cc-spec">
            <dd class="spec-v">{s.v}</dd>
            <dt class="spec-k">{s.k}</dt>
          </div>
        ))}
      </dl>
    )}

    {detalles.intercambios && (
      <p class="cc-interchange">↔ {detalles.intercambios}</p>
    )}

    <a href={waHref} target="_blank" rel="noopener" class="cc-cta">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      Solicitar info
    </a>
  </div>
</article>

<style>
  /* ── Card shell ── */
  .cc {
    background: #fff;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid #dce4f0;
    border-radius: 10px;
    box-shadow: 0 2px 8px rgba(2, 69, 152, 0.06);
    transition: border-color 0.22s ease, box-shadow 0.22s ease, transform 0.22s ease;
    cursor: default;
    height: 100%;
  }

  .cc:hover {
    border-color: #f2a900;
    box-shadow: 0 8px 28px rgba(2, 69, 152, 0.14);
    transform: translateY(-3px);
  }

  /* ── Image zone ── */
  .cc-img-zone {
    position: relative;
    background: #f5f7fb;
    width: 100%;
    height: 200px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid #eef2f8;
    flex-shrink: 0;
  }

  .cc-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    padding: 1rem;
    transition: transform 0.35s ease;
  }

  .cc:hover .cc-img {
    transform: scale(1.06);
  }

  /* ── Badge strip ── */
  .cc-badge-strip {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    gap: 0.3rem;
    padding: 0.45rem 0.6rem;
    background: linear-gradient(to top, rgba(245, 247, 251, 0.95), transparent);
    flex-wrap: wrap;
  }

  .cc-badge {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.5rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.22rem 0.6rem;
    border-radius: 3px;
    line-height: 1.5;
  }

  .badge-crono { background: #f2a900; color: #111; }
  .badge-cab   { background: #024598; color: #fff; }
  .badge-dama  { background: #c8245a; color: #fff; }
  .badge-fecha {
    background: rgba(2, 69, 152, 0.08);
    color: #024598;
    border: 1px solid rgba(2, 69, 152, 0.18);
  }

  /* ── Body ── */
  .cc-body {
    padding: 1rem 1.1rem 1rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .cc-header {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
    margin-bottom: 0.55rem;
  }

  .cc-prefix {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.55rem;
    font-weight: 700;
    color: #9aabbf;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    line-height: 1;
  }

  .cc-modelo {
    font-family: 'IBM Plex Mono', monospace;
    font-size: clamp(1rem, 2.2vw, 1.2rem);
    font-weight: 700;
    color: #024598;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0;
  }

  /* ── Hairline rule ── */
  .cc-rule {
    height: 1px;
    background: #eef2f8;
    margin-bottom: 0.65rem;
  }

  /* ── Specs grid ── */
  .cc-specs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem 0.4rem;
    margin: 0;
  }

  .cc-spec {
    display: flex;
    flex-direction: column;
    gap: 0.04rem;
  }

  .spec-v {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.7rem;
    font-weight: 600;
    color: #1a2a4a;
    line-height: 1.2;
    margin: 0;
  }

  .spec-k {
    font-family: var(--font-body);
    font-size: 0.52rem;
    font-weight: 700;
    color: #9aabbf;
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }

  /* ── Interchange line ── */
  .cc-interchange {
    margin-top: 0.55rem;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.56rem;
    color: #9aabbf;
    line-height: 1.4;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* ── CTA button ── */
  .cc-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: auto;
    padding-top: 0.85rem;
    text-decoration: none;
    background: #f2a900;
    color: #111;
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    padding: 0.5rem 1rem;
    border-radius: 6px;
    align-self: stretch;
    justify-content: center;
    margin-top: 0.85rem;
    transition: background 0.18s ease, transform 0.18s ease;
  }

  .cc-cta:hover {
    background: #d99500;
    transform: translateY(-1px);
  }
</style>

// Title split — for movements: "ETA 251.262" → prefix "ETA", model "251.262"
// For coronas/vidrios/modulos: titulo IS the ref, prefix is descriptive name
const spaceIdx = titulo.indexOf(' ');
const prefix   = isCorona
  ? (TIPO_LABEL[tipo ?? ''] ?? '')
  : isGorras
  ? (TIPO_LABEL[tipo ?? ''] ?? '')
  : (isVidrios || isModulos || isInsumos || isHerramientas || isJoyeria)
  ? (nombre ?? '')
  : (spaceIdx > -1 ? titulo.slice(0, spaceIdx) : '');
const modelNum = isCorona || isVidrios || isModulos || isInsumos || isHerramientas || isJoyeria || isGorras
  ? titulo
  : (spaceIdx > -1 ? titulo.slice(spaceIdx + 1) : titulo);

type SpecItem = { k: string; v: string };

const specs: SpecItem[] = isCorona
  ? [
      medida ? { k: 'Medida', v: medida.replace(/\s*[Xx]\s*/g, ' × ') } : null,
      rosca  ? { k: 'Rosca',  v: rosca } : null,
    ].filter((s): s is SpecItem => s !== null)
  : isVidrios
  ? [
      medida ? { k: 'Medida', v: medida } : null,
      grosor ? { k: 'Grosor', v: grosor } : null,
      forma  ? { k: 'Tipo',   v: forma.charAt(0) + forma.slice(1).toLowerCase() } : null,
    ].filter((s): s is SpecItem => s !== null)
  : isModulos
  ? [
      detalles.bateria     ? { k: 'Batería',    v: `Pila ${detalles.bateria}` } : null,
      detalles.dimensiones ? { k: 'Eje',        v: detalles.dimensiones }       : null,
      tipo                 ? { k: 'Tipo',       v: TIPO_LABEL[tipo] ?? tipo }    : null,
    ].filter((s): s is SpecItem => s !== null)
  : isInsumos
  ? [
      marca         ? { k: 'Marca',  v: marca }                          : null,
      especificacion ? { k: 'Espec.', v: especificacion.slice(0, 40) }   : null,
      tipo           ? { k: 'Cat.',   v: TIPO_LABEL[tipo] ?? tipo }       : null,
    ].filter((s): s is SpecItem => s !== null)
  : isHerramientas
  ? [
      tipo ? { k: 'Tipo', v: TIPO_LABEL[tipo] ?? tipo } : null,
    ].filter((s): s is SpecItem => s !== null)
  : isJoyeria
  ? [
      tipo ? { k: 'Tipo', v: TIPO_LABEL[tipo] ?? tipo } : null,
    ].filter((s): s is SpecItem => s !== null)
  : isGorras
  ? []
  : isWatch
  ? [
      tipo ? { k: 'Tipo', v: TIPO_LABEL[tipo] ?? tipo } : null,
    ].filter((s): s is SpecItem => s !== null)
  : [
      detalles.dimensiones      ? { k: 'Dimensiones', v: detalles.dimensiones }      : null,
      detalles.altura           ? { k: 'Altura',      v: `${detalles.altura}mm` }    : null,
      detalles.joyas != null    ? { k: 'Joyas',       v: String(detalles.joyas) }    : null,
      detalles.bateria          ? { k: 'Batería',     v: `CR ${detalles.bateria}` }  : null,
    ].filter((s): s is SpecItem => s !== null).slice(0, 4);

const SWATCH: Record<string, string> = {
  'PLATEADA': '#C0C0C8',
  'DORADA':   '#D4AF37',
  'NEGRA':    '#3a3a3a',
  'ORO ROSA': '#C88898',
};

const coronaColors = isCorona && color
  ? color.split(', ').map(c => c.trim())
  : [];
---

<article class="cc" data-img={imagenSrc} data-catalogo-src={imagenCatalogoSrc} data-title={titulo}>
  <!-- Image zone -->
  <div class="cc-img-zone">
    <img
      src={imagenSrc}
      alt=""
      class="cc-img"
      loading="lazy"
      decoding="async"
    />
    <!-- Badges -->
    <div class="cc-badge-strip">
      {isVidrios && forma ? (
        <span class={`cc-badge ${BADGE_CLASS[forma] ?? 'badge-acc'}`}>
          {forma.charAt(0) + forma.slice(1).toLowerCase()}
        </span>
      ) : tipo ? (
        <span class={`cc-badge ${BADGE_CLASS[tipo] ?? 'badge-cab'}`}>
          {TIPO_LABEL[tipo] ?? tipo}
        </span>
      ) : null}
      {!isCorona && !isVidrios && fecha && <span class="cc-badge badge-fecha">+ Fecha</span>}
    </div>
  </div>

  <!-- Info zone -->
  <div class="cc-body">
    <div class="cc-header">
      {prefix && <span class="cc-prefix">{prefix}</span>}
      <h3 class="cc-modelo">{modelNum}</h3>
    </div>

    {specs.length > 0 && (
      <div class="cc-rule"></div>
      <dl class="cc-specs">
        {specs.map(s => (
          <div class="cc-spec">
            <dd class="spec-v">{s.v}</dd>
            <dt class="spec-k">{s.k}</dt>
          </div>
        ))}
      </dl>
    )}

    {isCorona && coronaColors.length > 0 && (
      <div class="cc-swatches">
        {coronaColors.map(c => (
          <span
            class="cc-swatch"
            title={c}
            style={`background:${SWATCH[c] ?? '#888'}`}
          ></span>
        ))}
      </div>
    )}

    {!isCorona && detalles.intercambios && (
      <p class="cc-interchange">↔ {detalles.intercambios}</p>
    )}
  </div>
</article>

<style>
  /* ── Card shell ── */
  .cc {
    background: #fff;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid #dce4f0;
    border-radius: 10px;
    box-shadow: 0 2px 8px rgba(2, 69, 152, 0.06);
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
    height: 100%;
  }

  /* Force all children to be unselectabe/unblocking — clicks pass through to .cc */
  .cc,
  .cc * {
    cursor: pointer !important;
    -webkit-user-select: none !important;
    -moz-user-select: none !important;
    -ms-user-select: none !important;
    user-select: none !important;
    -webkit-touch-callout: none !important;
  }

  .cc * {
    pointer-events: none !important;
  }

  .cc:hover {
    border-color: #f2a900;
    box-shadow: 0 12px 32px rgba(2, 69, 152, 0.18);
    transform: translateY(-4px);
    outline: none;
  }

  /* ── Image zone ── */
  .cc-img-zone {
    position: relative;
    background: #f5f7fb;
    width: 100%;
    height: 200px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid #eef2f8;
    flex-shrink: 0;
  }

  .cc-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    padding: 1rem;
    transition: transform 0.35s ease;
  }

  .cc:hover .cc-img {

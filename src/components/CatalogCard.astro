---
interface Detalles {
  tipo?:         string;
  dimensiones?:  string;
  altura?:       string;
  joyas?:        number;
  bateria?:      string;
  placas?:       string;
  intercambios?: string;
}

interface Props {
  imagenSrc:          string;
  imagenCatalogoSrc:  string;
  titulo:             string;   // "ETA 251.262"
  descripcionCorta?:  string;
  detalles:           Detalles;
  tipo?:              string;
  fecha?:             boolean;
}

const { imagenSrc, imagenCatalogoSrc, titulo, detalles, tipo, fecha } = Astro.props;

const spaceIdx = titulo.indexOf(' ');
const prefix   = spaceIdx > -1 ? titulo.slice(0, spaceIdx)  : '';
const modelNum = spaceIdx > -1 ? titulo.slice(spaceIdx + 1) : titulo;

const BADGE_CLASS: Record<string, string> = {
  'CRONÓGRAFO': 'badge-crono',
  'CABALLERO':  'badge-cab',
  'DAMA':       'badge-dama',
};

const TIPO_LABEL: Record<string, string> = {
  'CRONÓGRAFO': 'Cronógrafo',
  'CABALLERO':  'Caballero',
  'DAMA':       'Dama',
};

type SpecItem = { k: string; v: string };

const specs: SpecItem[] = [
  detalles.dimensiones             ? { k: 'Dimensiones', v: detalles.dimensiones }    : null,
  detalles.altura                  ? { k: 'Altura',      v: `${detalles.altura}mm` }  : null,
  (detalles.joyas != null)         ? { k: 'Joyas',       v: String(detalles.joyas) }  : null,
  detalles.bateria                 ? { k: 'Batería',     v: `CR ${detalles.bateria}` }: null,
].filter((s): s is SpecItem => s !== null).slice(0, 4);

---

<article class="cc" data-img={imagenSrc} data-catalogo-src={imagenCatalogoSrc} data-title={titulo}>
  <!-- Image zone -->
  <div class="cc-img-zone">
    <img
      src={imagenSrc}
      alt=""
      class="cc-img"
      loading="lazy"
      decoding="async"
    />
    <!-- Badges -->
    <div class="cc-badge-strip">
      {tipo && (
        <span class={`cc-badge ${BADGE_CLASS[tipo] ?? 'badge-cab'}`}>
          {TIPO_LABEL[tipo] ?? tipo}
        </span>
      )}
      {fecha && <span class="cc-badge badge-fecha">+ Fecha</span>}
    </div>
  </div>

  <!-- Info zone -->
  <div class="cc-body">
    <div class="cc-header">
      {prefix && <span class="cc-prefix">{prefix}</span>}
      <h3 class="cc-modelo">{modelNum}</h3>
    </div>

    {specs.length > 0 && (
      <div class="cc-rule"></div>
      <dl class="cc-specs">
        {specs.map(s => (
          <div class="cc-spec">
            <dd class="spec-v">{s.v}</dd>
            <dt class="spec-k">{s.k}</dt>
          </div>
        ))}
      </dl>
    )}

    {detalles.intercambios && (
      <p class="cc-interchange">↔ {detalles.intercambios}</p>
    )}
  </div>
</article>

<style>
  /* ── Card shell ── */
  .cc {
    background: #fff;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid #dce4f0;
    border-radius: 10px;
    box-shadow: 0 2px 8px rgba(2, 69, 152, 0.06);
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
    cursor: pointer;
    user-select: none;
    height: 100%;
  }

  .cc:hover {
    border-color: #f2a900;
    box-shadow: 0 12px 32px rgba(2, 69, 152, 0.18);
    transform: translateY(-4px);
    outline: none;
  }

  /* ── Image zone ── */
  .cc-img-zone {
    position: relative;
    background: #f5f7fb;
    width: 100%;
    height: 200px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid #eef2f8;
    flex-shrink: 0;
  }

  .cc-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    padding: 1rem;
    transition: transform 0.35s ease;
  }

  .cc:hover .cc-img {
    transform: scale(1.06);
  }

  /* ── Badge strip ── */
  .cc-badge-strip {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    gap: 0.3rem;
    padding: 0.45rem 0.6rem;
    background: linear-gradient(to top, rgba(245, 247, 251, 0.95), transparent);
    flex-wrap: wrap;
  }

  .cc-badge {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.5rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.22rem 0.6rem;
    border-radius: 3px;
    line-height: 1.5;
  }

  .badge-crono { background: #f2a900; color: #111; }
  .badge-cab   { background: #024598; color: #fff; }
  .badge-dama  { background: #c8245a; color: #fff; }
  .badge-fecha {
    background: rgba(2, 69, 152, 0.08);
    color: #024598;
    border: 1px solid rgba(2, 69, 152, 0.18);
  }

  /* ── Body ── */
  .cc-body {
    padding: 1rem 1.1rem 1rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .cc-header {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
    margin-bottom: 0.55rem;
  }

  .cc-prefix {
    font-family: var(--font-body);
    font-size: 0.6rem;
    font-weight: 600;
    color: #9aabbf;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    line-height: 1;
  }

  .cc-modelo {
    font-family: var(--font-heading);
    font-size: clamp(1rem, 2.2vw, 1.15rem);
    font-weight: 800;
    color: #024598;
    letter-spacing: -0.01em;
    line-height: 1.1;
    margin: 0;
  }

  /* ── Hairline rule ── */
  .cc-rule {
    height: 1px;
    background: #eef2f8;
    margin-bottom: 0.65rem;
  }

  /* ── Specs grid ── */
  .cc-specs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem 0.4rem;
    margin: 0;
  }

  .cc-spec {
    display: flex;
    flex-direction: column;
    gap: 0.04rem;
  }

  .spec-v {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 500;
    color: #1a2a4a;
    line-height: 1.2;
    margin: 0;
  }

  .spec-k {
    font-family: var(--font-body);
    font-size: 0.52rem;
    font-weight: 600;
    color: #9aabbf;
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }

  /* ── Interchange line ── */
  .cc-interchange {
    margin-top: 0.55rem;
    font-family: var(--font-body);
    font-size: 0.58rem;
    font-weight: 400;
    color: #9aabbf;
    line-height: 1.4;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
</style>

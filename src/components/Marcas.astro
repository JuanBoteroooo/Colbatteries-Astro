---
const brands = [
  { name: 'Miyota', category: 'Movimientos' },
  { name: 'ETA', category: 'Movimientos' },
  { name: 'Ronda', category: 'Movimientos' },
  { name: 'ISA', category: 'Movimientos' },
  { name: 'Epson', category: 'Movimientos' },
  { name: 'SII', category: 'Movimientos' },
  { name: 'Renata', category: 'Baterías' },
  { name: 'GP', category: 'Baterías' },
  { name: 'Maxell', category: 'Baterías' },
  { name: 'Tianqiu', category: 'Baterías' },
  { name: 'Polemik', category: 'Relojes' },
  { name: 'Q&Q', category: 'Relojes' },
];
---

<section class="marcas-section" id="marcas">
  <div class="container">
    <div class="marcas-header reveal">
      <span class="section-tag">Marcas que distribuimos</span>
      <h2 class="section-title">Trabajamos con los <span>mejores</span></h2>
    </div>
  </div>

  <div class="carousel-wrapper">
    <div class="carousel-track" id="carouselTrack">
      {brands.map(b => (
        <div class="brand-chip">
          <span class="brand-name">{b.name}</span>
          <span class="brand-cat">{b.category}</span>
        </div>
      ))}
      {brands.map(b => (
        <div class="brand-chip" aria-hidden="true">
          <span class="brand-name">{b.name}</span>
          <span class="brand-cat">{b.category}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .marcas-section {
    padding: 5rem 0;
    background: var(--white);
    overflow: hidden;
    border-top: 1px solid var(--gray-200);
    border-bottom: 1px solid var(--gray-200);
  }

  .marcas-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .carousel-wrapper {
    position: relative;
    overflow: hidden;
    padding: 1rem 0;
  }

  .carousel-wrapper::before,
  .carousel-wrapper::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 120px;
    z-index: 2;
    pointer-events: none;
  }

  .carousel-wrapper::before {
    left: 0;
    background: linear-gradient(to right, var(--white), transparent);
  }

  .carousel-wrapper::after {
    right: 0;
    background: linear-gradient(to left, var(--white), transparent);
  }

  .carousel-track {
    display: flex;
    gap: 1.25rem;
    animation: scroll 30s linear infinite;
    width: max-content;
  }

  .carousel-track:hover {
    animation-play-state: paused;
  }

  @keyframes scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  .brand-chip {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    padding: 0.85rem 1.75rem;
    white-space: nowrap;
    position: relative;
    border-radius: 12px;
    border: 1.5px solid transparent;
    overflow: hidden;
    cursor: default;
    transition:
      border-color 0.3s ease,
      background 0.3s ease,
      box-shadow 0.3s ease,
      transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* shimmer sweep */
  .brand-chip::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(
      105deg,
      transparent 20%,
      rgba(255,255,255,0.55) 50%,
      transparent 80%
    );
    transition: left 0.55s ease;
    pointer-events: none;
    z-index: 1;
  }

  .brand-chip:hover::before { left: 160%; }

  .brand-chip:hover {
    border-color: rgba(242,169,0,0.4);
    background: rgba(242,169,0,0.05);
    box-shadow:
      0 0 0 1px rgba(242,169,0,0.2),
      0 6px 24px rgba(242,169,0,0.12);
    transform: translateY(-3px);
  }

  .brand-name {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 800;
    color: rgba(2,29,80,0.45);
    letter-spacing: 0.04em;
    transition: color 0.3s ease;
  }

  .brand-chip:hover .brand-name { color: var(--blue); }

  .brand-cat {
    font-size: 0.6rem;
    color: rgba(2,69,152,0.3);
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    transition: color 0.3s ease;
  }

  .brand-chip:hover .brand-cat { color: rgba(242,169,0,0.8); }
</style>

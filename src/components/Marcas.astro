---
const brands = [
  { name: 'Miyota',  category: 'Movimientos', logo: '/images/marcas/miyota.svg',       href: '/catalogo?q=miyota'   },
  { name: 'ETA',     category: 'Movimientos', logo: '/images/marcas/eta.png',          href: '/catalogo?q=eta'      },
  { name: 'Ronda',   category: 'Movimientos', logo: '/images/marcas/ronda.svg',        href: '/catalogo?q=ronda'    },
  { name: 'ISA',     category: 'Movimientos', logo: '/images/marcas/isa-logo.png',     href: '/catalogo?q=isa',     big: true },
  { name: 'Epson',   category: 'Movimientos', logo: '/images/marcas/epson.svg',        href: '/catalogo?q=epson'    },
  { name: 'SII',     category: 'Movimientos', logo: '/images/marcas/sii.png',          href: '/catalogo?q=sii',     big: true },
  { name: 'Renata',  category: 'Baterías',    logo: '/images/marcas/renata.svg',       href: '/catalogo'            },
  { name: 'GP',      category: 'Baterías',    logo: '/images/marcas/gp-logo.png',      href: '/catalogo?q=gp',      big: true },
  { name: 'Maxell',  category: 'Baterías',    logo: '/images/marcas/maxell.svg',       href: '/catalogo?q=maxell'   },
  { name: 'Tianqiu', category: 'Baterías',    logo: '/images/marcas/tianqiu-logo.png', href: '/catalogo?q=tianqiu', xl: true },
  { name: 'Polemik', category: 'Relojes',     logo: '/images/marcas/polemik-logo.png', xl: true },
  { name: 'Q&Q',     category: 'Relojes',     logo: '/images/marcas/qq.png',           href: '/catalogo',           xl: true },
];
---

<section class="marcas-section" id="marcas">
  <div class="container">
    <div class="marcas-header reveal">
      <span class="section-tag">Marcas que distribuimos</span>
      <h2 class="section-title">Trabajamos con los <span>mejores</span></h2>
    </div>
  </div>

  <div class="carousel-wrapper">
    <div class="carousel-track" id="carouselTrack">
      {brands.map(b => (
        b.href
          ? <a href={b.href} class="brand-chip">
              {b.logo
                ? <img src={b.logo} alt={b.name} class={`brand-logo${b.xl ? ' brand-logo--xl' : b.big ? ' brand-logo--big' : ''}`} loading="lazy" />
                : <Fragment><span class="brand-name">{b.name}</span><span class="brand-cat">{b.category}</span></Fragment>
              }
            </a>
          : <div class="brand-chip">
              {b.logo
                ? <img src={b.logo} alt={b.name} class={`brand-logo${b.xl ? ' brand-logo--xl' : b.big ? ' brand-logo--big' : ''}`} loading="lazy" />
                : <Fragment><span class="brand-name">{b.name}</span><span class="brand-cat">{b.category}</span></Fragment>
              }
            </div>
      ))}
      {brands.map(b => (
        <div class="brand-chip" aria-hidden="true">
          {b.logo
            ? <img src={b.logo} alt="" class={`brand-logo${b.xl ? ' brand-logo--xl' : b.big ? ' brand-logo--big' : ''}`} loading="lazy" />
            : <Fragment><span class="brand-name">{b.name}</span><span class="brand-cat">{b.category}</span></Fragment>
          }
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .marcas-section {
    padding: 5rem 0;
    background: var(--white);
    overflow: hidden;
    border-top: 1px solid var(--gray-200);
    border-bottom: 1px solid var(--gray-200);
  }

  .marcas-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .carousel-wrapper {
    position: relative;
    overflow: hidden;
    padding: 1rem 0;
  }

  .carousel-wrapper::before,
  .carousel-wrapper::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 120px;
    z-index: 2;
    pointer-events: none;
  }

  .carousel-wrapper::before {
    left: 0;
    background: linear-gradient(to right, var(--white), transparent);
  }

  .carousel-wrapper::after {
    right: 0;
    background: linear-gradient(to left, var(--white), transparent);
  }

  .carousel-track {
    display: flex;
    align-items: center;
    gap: 1rem;
    animation: scroll 32s linear infinite;
    width: max-content;
  }

  .carousel-track:hover {
    animation-play-state: paused;
  }

  @keyframes scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* ── CHIP ── */
  .brand-chip {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    padding: 0.85rem 1.75rem;
    min-width: 130px;
    height: 80px;
    white-space: nowrap;
    position: relative;
    border-radius: 12px;
    border: 1.5px solid transparent;
    overflow: hidden;
    cursor: default;
  text-decoration: none;
    transition:
      border-color 0.3s ease,
      background 0.3s ease,
      box-shadow 0.3s ease,
      transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* shimmer sweep */
  .brand-chip::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(
      105deg,
      transparent 20%,
      rgba(255,255,255,0.55) 50%,
      transparent 80%
    );
    transition: left 0.55s ease;
    pointer-events: none;
    z-index: 1;
  }

  .brand-chip:hover::before { left: 160%; }

  a.brand-chip { cursor: pointer; }

  .brand-chip:hover {
    border-color: rgba(242,169,0,0.4);
    background: rgba(242,169,0,0.05);
    box-shadow:
      0 0 0 1px rgba(242,169,0,0.2),
      0 6px 24px rgba(242,169,0,0.12);
    transform: translateY(-3px);
  }

  /* ── LOGO IMAGE ── */
  .brand-logo {
    max-height: 38px;
    max-width: 120px;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: grayscale(1) opacity(0.42);
    transition: filter 0.35s ease;
    position: relative;
    z-index: 0;
  }

  .brand-logo--big {
    max-height: 44px;
    max-width: 150px;
  }

  .brand-logo--xl {
    max-height: 62px;
    max-width: 180px;
  }

  .brand-chip:hover .brand-logo {
    filter: grayscale(0) opacity(1);
  }

  /* ── TEXT FALLBACK (brands without logo) ── */
  .brand-name {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 800;
    color: rgba(2,29,80,0.45);
    letter-spacing: 0.04em;
    transition: color 0.3s ease;
    position: relative;
    z-index: 0;
  }

  .brand-chip:hover .brand-name { color: var(--blue); }

  .brand-cat {
    font-size: 0.6rem;
    color: rgba(2,69,152,0.3);
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    transition: color 0.3s ease;
    position: relative;
    z-index: 0;
  }

  .brand-chip:hover .brand-cat { color: rgba(242,169,0,0.8); }
</style>

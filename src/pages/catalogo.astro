---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const catalogs = [
  {
    id: 'baterias',
    title: 'Catálogo de Baterías',
    desc: 'Pilas de botón plata, litio CR y alcalinas AG con referencias completas, equivalencias y tablas de compatibilidad.',
    count: '+300 refs',
    brands: ['Renata', 'GP', 'Maxell', 'Tianqiu'],
    accentColor: '#e64132',
    pages: '48 págs.',
    year: '2024',
  },
  {
    id: 'movimientos',
    title: 'Catálogo de Movimientos',
    desc: 'Movimientos de cuarzo y automáticos con dimensiones, calibres y especificaciones técnicas detalladas.',
    count: '+200 refs',
    brands: ['Miyota', 'ETA', 'Ronda', 'ISA', 'Epson'],
    accentColor: '#024598',
    pages: '64 págs.',
    year: '2024',
  },
  {
    id: 'relojes',
    title: 'Catálogo de Relojes',
    desc: 'Colecciones completas Polemik, Xinjia y Q&Q para caballero, dama y junior. Precios de distribuidor.',
    count: '+150 modelos',
    brands: ['Polemik', 'Xinjia', 'Q&Q'],
    accentColor: '#013370',
    pages: '96 págs.',
    year: '2024',
  },
  {
    id: 'correas',
    title: 'Catálogo de Correas & Bandas',
    desc: 'Cuero, silicona, resina, metal y PVC. Anchos del 10mm al 24mm, todos los colores disponibles.',
    count: '+400 refs',
    brands: ['Cuero', 'Silicona', 'Metal', 'Resina', 'PVC'],
    accentColor: '#e64132',
    pages: '36 págs.',
    year: '2024',
  },
  {
    id: 'cristales',
    title: 'Catálogo de Cristales & Vidrios',
    desc: 'Minerales, sapiro y acrílico. Formas redondas, rectangulares, cuadradas y ovales para todas las marcas.',
    count: '+500 refs',
    brands: ['Mineral', 'Sapiro', 'Acrílico'],
    accentColor: '#024598',
    pages: '52 págs.',
    year: '2024',
  },
  {
    id: 'herramientas',
    title: 'Catálogo de Herramientas',
    desc: 'Equipos y herramientas profesionales para relojería. Kits completos de servicio y reparación.',
    count: '+100 refs',
    brands: ['Bergeon', 'Horotec', 'Surtido'],
    accentColor: '#013370',
    pages: '24 págs.',
    year: '2024',
  },
];
---

<Layout title="Catálogos — Colbateries S.A." description="Catálogos de productos de relojería, baterías, correas y accesorios. Más de 1,500 referencias disponibles.">
  <Navbar />

  <main class="page-main">
    <!-- Hero -->
    <section class="page-hero">
      <div class="container">
        <p class="page-eyebrow">Distribución especializada</p>
        <h1 class="page-title">Nuestros <span>Catálogos</span></h1>
        <p class="page-desc">Descargue o solicite nuestros catálogos especializados. Más de 1,500 referencias con precios de distribuidor.</p>
      </div>
    </section>

    <!-- Catalog grid -->
    <section class="catalogs-section">
      <div class="container">
        <div class="catalogs-grid">
          {catalogs.map((cat, i) => (
            <div class={`catalog-card reveal delay-${(i % 3) * 100}`}>
              <div class="card-header" style={`background: ${cat.accentColor}`}>
                <div class="pdf-icon">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                    <polyline points="14,2 14,8 20,8"/>
                    <line x1="16" y1="13" x2="8" y2="13"/>
                    <line x1="16" y1="17" x2="8" y2="17"/>
                    <polyline points="10,9 9,9 8,9"/>
                  </svg>
                </div>
                <div class="card-meta">
                  <span class="meta-pages">{cat.pages}</span>
                  <span class="meta-year">{cat.year}</span>
                </div>
              </div>

              <div class="card-body">
                <span class="cat-count-badge">{cat.count}</span>
                <h3 class="card-title">{cat.title}</h3>
                <p class="card-desc">{cat.desc}</p>

                <div class="brand-pills">
                  {cat.brands.map(b => (
                    <span class="brand-pill">{b}</span>
                  ))}
                </div>

                <a
                  href={`https://wa.me/50764156382?text=${encodeURIComponent(`Hola, quisiera solicitar el ${cat.title} de Colbateries S.A.`)}`}
                  target="_blank"
                  rel="noopener"
                  class="card-cta"
                >
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                  Solicitar catálogo
                </a>
              </div>
            </div>
          ))}
        </div>

        <div class="info-banner reveal">
          <div class="info-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <line x1="12" y1="8" x2="12" y2="12"/>
              <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
          </div>
          <p>Los catálogos se envían en formato PDF por WhatsApp o correo electrónico. Actualización permanente de referencias y precios.</p>
          <a href="/contacto" class="info-link">Ver formas de contacto →</a>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-section">
      <div class="container cta-inner">
        <div>
          <h2 class="cta-title">¿Tiene una consulta específica?</h2>
          <p class="cta-sub">Escríbanos y le ayudamos con su pedido o cotización.</p>
        </div>
        <a href="https://wa.me/50764156382" target="_blank" rel="noopener" class="btn-primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Escribir por WhatsApp
        </a>
      </div>
    </section>
  </main>

  <Footer />

  <a href="https://wa.me/50764156382" target="_blank" rel="noopener" class="wa-float" aria-label="WhatsApp">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
  </a>
</Layout>

<style>
  .page-main { padding-top: 80px; }

  .page-hero {
    background: var(--gray-100);
    padding: 5rem 0 4rem;
    text-align: center;
    border-bottom: 1px solid var(--gray-200);
  }

  .page-eyebrow {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 1rem;
  }

  .page-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 900;
    color: var(--blue);
    margin-bottom: 1rem;
    line-height: 1.1;
  }

  .page-title span { color: var(--red); }

  .page-desc {
    font-size: 1.05rem;
    color: var(--gray-700);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* Catalog grid */
  .catalogs-section {
    padding: 5rem 0;
    background: var(--white);
  }

  .catalogs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.75rem;
    margin-bottom: 3rem;
  }

  .catalog-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: 16px;
    overflow: hidden;
    transition: transform var(--transition), box-shadow var(--transition);
  }

  .catalog-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
  }

  .card-header {
    padding: 2rem 1.75rem 1.5rem;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    position: relative;
  }

  .pdf-icon {
    width: 56px;
    height: 56px;
    background: rgba(255,255,255,0.15);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--white);
  }

  .card-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.25rem;
  }

  .meta-pages {
    font-size: 0.75rem;
    font-weight: 700;
    color: rgba(255,255,255,0.9);
    background: rgba(255,255,255,0.15);
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
  }

  .meta-year {
    font-size: 0.7rem;
    color: rgba(255,255,255,0.6);
    font-weight: 500;
  }

  .card-body {
    padding: 1.5rem 1.75rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .cat-count-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--red);
    background: rgba(230,65,50,0.08);
    padding: 0.25rem 0.65rem;
    border-radius: 20px;
    width: fit-content;
  }

  .card-title {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--blue);
    line-height: 1.3;
    margin: 0;
  }

  .card-desc {
    font-size: 0.875rem;
    color: var(--gray-700);
    line-height: 1.65;
    margin: 0;
  }

  .brand-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.25rem;
  }

  .brand-pill {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--blue);
    background: rgba(2,69,152,0.07);
    border: 1px solid rgba(2,69,152,0.15);
    padding: 0.2rem 0.6rem;
    border-radius: 6px;
  }

  .card-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    background: var(--blue);
    color: var(--white);
    font-size: 0.875rem;
    font-weight: 700;
    border-radius: 8px;
    margin-top: 0.5rem;
    transition: background var(--transition), transform var(--transition);
    align-self: flex-start;
  }

  .card-cta:hover {
    background: var(--blue-dark);
    transform: translateY(-2px);
  }

  /* Info banner */
  .info-banner {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: rgba(2,69,152,0.04);
    border: 1px solid rgba(2,69,152,0.1);
    border-left: 4px solid var(--blue);
    border-radius: 0 12px 12px 0;
    padding: 1.25rem 1.5rem;
    font-size: 0.9rem;
    color: var(--gray-700);
    line-height: 1.6;
    flex-wrap: wrap;
  }

  .info-icon { color: var(--blue); flex-shrink: 0; }

  .info-banner p { flex: 1; margin: 0; }

  .info-link {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--blue);
    white-space: nowrap;
    transition: color var(--transition);
  }

  .info-link:hover { color: var(--red); }

  /* CTA strip */
  .cta-section {
    background: var(--blue);
    padding: 3.5rem 0;
  }

  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .cta-title {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--white);
    margin-bottom: 0.3rem;
  }

  .cta-sub { font-size: 0.95rem; color: rgba(255,255,255,0.7); }

  .wa-float {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 58px;
    height: 58px;
    background: #25D366;
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 999;
    box-shadow: 0 4px 20px rgba(37,211,102,0.4);
    transition: transform var(--transition);
  }

  .wa-float:hover { transform: scale(1.1); }

  @media (max-width: 900px) {
    .catalogs-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 560px) {
    .catalogs-grid { grid-template-columns: 1fr; }
    .cta-inner { flex-direction: column; text-align: center; }
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => e.isIntersecting && e.target.classList.add('visible')),
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.reveal, .reveal-left, .reveal-right').forEach(el => observer.observe(el));
</script>

---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import { allCatalogs, groups } from '../../data/catalogs.js';

export function getStaticPaths() {
  const catalogs = groups.flatMap(g =>
    g.catalogs.map(c => ({ ...c, group: g.name, groupId: g.id, image: g.image }))
  );
  return catalogs.map(cat => ({ params: { slug: cat.slug }, props: { cat } }));
}

const { cat } = Astro.props;
const { slug } = Astro.params;

const group = groups.find(g => g.id === cat.groupId);
const groupCats = group?.catalogs ?? [];
const idx = groupCats.findIndex(c => c.slug === slug);
const prev = idx > 0 ? groupCats[idx - 1] : null;
const next = idx < groupCats.length - 1 ? groupCats[idx + 1] : null;

const waMsg = encodeURIComponent(`Hola, quisiera solicitar el catálogo de ${cat.label} de Colbateries S.A.`);

const labelUpper = cat.label.toUpperCase();
const words = labelUpper.split(' ');
const midpoint = Math.ceil(words.length / 2);
const line1 = words.slice(0, midpoint).join(' ');
const line2 = words.slice(midpoint).join(' ');
---

<Layout
  title={`Catálogo ${cat.label} — Colbateries S.A.`}
  description={`Catálogo de ${cat.label}. Distribución mayorista Colbateries S.A., Zona Libre de Colón, Panamá.`}
>
  <Navbar />

  <div class="viewer-page">

    <!-- Loading overlay -->
    <div class="pdf-loading" id="pdfLoading">
      <div class="loading-inner">
        <img src="/logo.jpeg" alt="Colbateries" class="loading-logo" />
        <p class="loading-cat">{cat.label}</p>
        <div class="progress-track">
          <div class="progress-fill" id="progressFill"></div>
        </div>
        <p class="progress-pct" id="progressPct">0%</p>
      </div>
    </div>

    <!-- Top bar -->
    <div class="viewer-bar">
      <div class="bar-left">
        <a href="/catalogo" class="breadcrumb">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <polyline points="15 18 9 12 15 6"/>
          </svg>
          Catálogos
        </a>
        <span class="breadcrumb-sep">/</span>
        <span class="breadcrumb-current">{cat.label}</span>
      </div>

      <div class="bar-nav">
        {prev ? (
          <a href={`/catalogo/${prev.slug}`} class="nav-btn" title={prev.label}>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
            <span class="nav-label">Anterior</span>
          </a>
        ) : (
          <span class="nav-btn disabled">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
          </span>
        )}
        <span class="nav-pos">{idx + 1} <span class="nav-pos-of">de</span> {groupCats.length}</span>
        {next ? (
          <a href={`/catalogo/${next.slug}`} class="nav-btn" title={next.label}>
            <span class="nav-label">Siguiente</span>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
          </a>
        ) : (
          <span class="nav-btn disabled">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
          </span>
        )}
      </div>

      <div class="bar-actions">
        <a href={`/catalogos/${slug}.pdf`} download class="btn-dl">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          Descargar
        </a>
        <a href={`https://wa.me/50764156382?text=${waMsg}`} target="_blank" rel="noopener" class="btn-wa">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Solicitar
        </a>
      </div>
    </div>

    <!-- PDF frame (iframe for better zoom control) -->
    <div class="viewer-frame" id="viewerFrame">
      <iframe
        id="pdfFrame"
        title={`Catálogo ${cat.label}`}
        class="pdf-iframe"
        allowfullscreen
      ></iframe>

      <!-- Fallback cover (shown if PDF doesn't exist) -->
      <div class="pdf-cover" id="pdfCover" style="display:none">
        <div class="cover-inner">
          <div class="cover-logo-strip">
            <img src="/logo.jpeg" alt="Colbateries S.A." class="cover-logo-img" />
          </div>
          <div class="cover-divider"></div>
          <div class="cover-text">
            <p class="cover-line cover-line-1">CATÁLOGO</p>
            {line1 !== 'CATÁLOGO' && <p class="cover-line cover-line-2">{line1}</p>}
            {line2 && <p class="cover-line cover-line-3">{line2}</p>}
          </div>
          <div class="cover-footer">
            <a href={`https://wa.me/50764156382?text=${waMsg}`} target="_blank" rel="noopener" class="cover-cta">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Solicitar este catálogo por WhatsApp
            </a>
            <p class="cover-note">El catálogo se envía en PDF de inmediato</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom navigation -->
    <div class="viewer-footer">
      <div class="footer-group">
        <span class="footer-group-label">{cat.group}</span>
        <div class="footer-siblings">
          {groupCats.map(c => (
            <a
              href={`/catalogo/${c.slug}`}
              class={`sibling-pill ${c.slug === slug ? 'active' : ''}`}
            >
              {c.label}
            </a>
          ))}
        </div>
      </div>
    </div>

  </div>
</Layout>

<style>
  .viewer-page {
    display: flex;
    flex-direction: column;
    height: 100vh;
    padding-top: 78px;
    background: #161616;
  }

  /* ── LOADING OVERLAY ── */
  .pdf-loading {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: #161616;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.45s ease;
  }

  .loading-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    width: min(320px, 80vw);
  }

  .loading-logo {
    height: 52px;
    width: auto;
    object-fit: contain;
    filter: brightness(0) invert(1);
    opacity: 0.9;
    margin-bottom: 0.5rem;
  }

  .loading-cat {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    color: rgba(255,255,255,0.55);
    letter-spacing: 0.04em;
    text-align: center;
  }

  .progress-track {
    width: 100%;
    height: 3px;
    background: rgba(255,255,255,0.1);
    border-radius: 2px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    width: 0%;
    background: var(--yellow);
    border-radius: 2px;
    transition: width 0.25s ease;
    box-shadow: 0 0 8px rgba(242,169,0,0.6);
  }

  .progress-pct {
    font-size: 0.72rem;
    font-weight: 700;
    color: rgba(255,255,255,0.35);
    letter-spacing: 0.06em;
    font-variant-numeric: tabular-nums;
  }

  /* ── TOP BAR ── */
  .viewer-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0 1.5rem;
    height: 48px;
    background: #212121;
    border-bottom: 1px solid #2e2e2e;
    flex-shrink: 0;
    flex-wrap: nowrap;
  }

  .bar-left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
    flex: 1;
  }

  .breadcrumb {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: #888;
    text-decoration: none;
    transition: color 0.2s;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .breadcrumb:hover { color: var(--yellow); }

  .breadcrumb-sep { color: #444; font-size: 0.85rem; flex-shrink: 0; }

  .breadcrumb-current {
    font-size: 0.82rem;
    font-weight: 700;
    color: #ddd;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Prev / Next */
  .bar-nav {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-shrink: 0;
  }

  .nav-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.3rem 0.6rem;
    background: #2e2e2e;
    border: 1px solid #3a3a3a;
    border-radius: 6px;
    color: #aaa;
    font-size: 0.78rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    white-space: nowrap;
  }

  .nav-btn:not(.disabled):hover {
    background: var(--yellow);
    border-color: var(--yellow);
    color: #111;
  }

  .nav-btn.disabled { opacity: 0.25; cursor: default; }

  .nav-label { font-size: 0.76rem; }

  .nav-pos {
    font-size: 0.78rem;
    font-weight: 600;
    color: #666;
    padding: 0 0.4rem;
    white-space: nowrap;
  }

  .nav-pos-of { font-weight: 400; }

  /* Actions */
  .bar-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .btn-dl {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.8rem;
    background: #2e2e2e;
    border: 1px solid #3a3a3a;
    border-radius: 6px;
    color: #aaa;
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
    white-space: nowrap;
  }

  .btn-dl:hover { background: #3a3a3a; color: #fff; }

  .btn-wa {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 1rem;
    background: #25D366;
    border-radius: 6px;
    color: #fff;
    font-size: 0.8rem;
    font-weight: 700;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
    white-space: nowrap;
  }

  .btn-wa:hover { background: #1da851; transform: translateY(-1px); }

  /* ── PDF FRAME ── */
  .viewer-frame {
    flex: 1;
    overflow: hidden;
    position: relative;
    background: #1e1e1e;
  }

  .pdf-iframe {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }

  /* ── COVER FALLBACK ── */
  .pdf-cover {
    position: absolute;
    inset: 0;
    background: #f0f0f0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: auto;
  }

  .cover-inner {
    width: min(700px, 90%);
    background: var(--white);
    aspect-ratio: 8.5 / 11;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 3rem;
    box-shadow: 0 8px 40px rgba(0,0,0,0.3);
    text-align: center;
    gap: 2rem;
  }

  .cover-logo-strip { display: flex; align-items: center; justify-content: center; }

  .cover-logo-img { height: 80px; width: auto; object-fit: contain; }

  .cover-divider {
    width: 60px;
    height: 3px;
    background: var(--yellow);
    border-radius: 2px;
  }

  .cover-text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .cover-line {
    font-family: var(--font-heading);
    font-weight: 900;
    line-height: 1.05;
    color: var(--gray-900);
  }

  .cover-line-1 { font-size: clamp(2rem, 8vw, 4rem); }
  .cover-line-2 { font-size: clamp(1.5rem, 6vw, 3rem); }
  .cover-line-3 { font-size: clamp(1.5rem, 6vw, 3rem); color: var(--blue); }

  .cover-footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .cover-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: #25D366;
    color: #fff;
    font-size: 0.875rem;
    font-weight: 700;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
    box-shadow: 0 4px 16px rgba(37,211,102,0.3);
  }

  .cover-cta:hover { background: #1da851; transform: translateY(-2px); }

  .cover-note { font-size: 0.78rem; color: var(--gray-700); font-weight: 500; }

  /* ── FOOTER NAV ── */
  .viewer-footer {
    background: #212121;
    border-top: 1px solid #2e2e2e;
    padding: 0.6rem 1.5rem;
    flex-shrink: 0;
  }

  .footer-group {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-group-label {
    font-size: 0.72rem;
    font-weight: 700;
    color: #555;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    white-space: nowrap;
  }

  .footer-siblings {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .sibling-pill {
    font-size: 0.73rem;
    font-weight: 600;
    padding: 0.22rem 0.65rem;
    border-radius: 20px;
    text-decoration: none;
    background: #2a2a2a;
    color: #888;
    border: 1px solid #333;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    white-space: nowrap;
  }

  .sibling-pill:hover { background: #3a3a3a; color: #ddd; }

  .sibling-pill.active {
    background: var(--yellow);
    color: #111;
    border-color: var(--yellow);
    font-weight: 700;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 640px) {
    .viewer-bar { padding: 0 0.75rem; }
    .bar-left { display: none; }
    .nav-label { display: none; }
    .cover-inner { padding: 2rem 1.5rem; }
    .viewer-footer { padding: 0.5rem 0.75rem; }
  }
</style>

<script define:vars={{ slug, catLabel: cat.label }}>
  const fill   = document.getElementById('progressFill');
  const pctEl  = document.getElementById('progressPct');
  const loader = document.getElementById('pdfLoading');
  const frame  = document.getElementById('pdfFrame');
  const cover  = document.getElementById('pdfCover');
  const pdfUrl = `/catalogos/${slug}.pdf`;

  // ── Progress animation ──
  let current = 0;
  const phases = [
    { target: 28, ms: 350 },
    { target: 65, ms: 1600 },
    { target: 85, ms: 1800 },
  ];
  let pi = 0, from = 0, phaseStart = Date.now();

  function setProgress(v) {
    current = Math.min(v, 99);
    if (fill) fill.style.width = current + '%';
    if (pctEl) pctEl.textContent = current + '%';
  }

  function tick() {
    if (pi >= phases.length) return;
    const { target, ms } = phases[pi];
    const t = Math.min((Date.now() - phaseStart) / ms, 1);
    const eased = 1 - Math.pow(1 - t, 2);
    setProgress(Math.round(from + (target - from) * eased));
    if (t < 1) { requestAnimationFrame(tick); }
    else { from = target; pi++; phaseStart = Date.now(); if (pi < phases.length) requestAnimationFrame(tick); }
  }
  requestAnimationFrame(tick);

  // ── Hide loader ──
  function hideLoader() {
    if (!loader) return;
    setProgress(100);
    if (pctEl) pctEl.textContent = '100%';
    setTimeout(() => {
      loader.style.opacity = '0';
      setTimeout(() => { loader.style.display = 'none'; }, 450);
    }, 280);
  }

  // ── Check PDF exists, then set src ──
  fetch(pdfUrl, { method: 'HEAD' })
    .then(r => {
      if (r.ok) {
        // PDF exists — load it with fit-width param
        frame.src = `${pdfUrl}#view=FitH&toolbar=0`;
        frame.addEventListener('load', hideLoader, { once: true });
      } else {
        // PDF not found — show cover fallback
        if (frame) frame.style.display = 'none';
        if (cover) cover.style.display = 'flex';
        hideLoader();
      }
    })
    .catch(() => {
      if (frame) frame.style.display = 'none';
      if (cover) cover.style.display = 'flex';
      hideLoader();
    });

  // Safety timeout
  setTimeout(hideLoader, 12000);
</script>

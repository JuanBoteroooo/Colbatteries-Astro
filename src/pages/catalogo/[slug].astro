---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import CatalogCard from '../../components/CatalogCard.astro';
import { groups } from '../../data/catalogs.js';
import coronasData from '../../data/coronas.json';
import etaData from '../../data/movimientos-eta.json';

export function getStaticPaths() {
  const catalogs = groups.flatMap(g =>
    g.catalogs.map(c => ({ ...c, group: g.name, groupId: g.id, image: g.image }))
  );
  return catalogs.map(cat => ({ params: { slug: cat.slug }, props: { cat } }));
}

const { cat } = Astro.props;
const { slug } = Astro.params;

const group = groups.find(g => g.id === cat.groupId);
const groupCats = group?.catalogs ?? [];
const idx = groupCats.findIndex(c => c.slug === slug);
const prev = idx > 0 ? groupCats[idx - 1] : null;
const next = idx < groupCats.length - 1 ? groupCats[idx + 1] : null;

const waMsg = encodeURIComponent(`Hola, quisiera solicitar el catálogo de ${cat.label} de Colbateries S.A.`);
const isStructured = !!cat.structured;
const isGallery = !isStructured && !!cat.pages;
const isETA     = isStructured && slug === 'movimientos-eta';
const isCoronas = isStructured && slug === 'coronas';
const products  = isCoronas ? coronasData : isETA ? etaData : [];

// For cover fallback (PDF mode only)
const labelUpper = cat.label.toUpperCase();
const words = labelUpper.split(' ');
const mid = Math.ceil(words.length / 2);
const line1 = words.slice(0, mid).join(' ');
const line2 = words.slice(mid).join(' ');

// Gallery pages
const pageNums = isGallery ? Array.from({ length: cat.pages }, (_, i) => i + 1) : [];
---

<Layout
  title={`Catálogo ${cat.label} — Colbateries S.A.`}
  description={`Catálogo de ${cat.label}. Distribución mayorista Colbateries S.A., Zona Libre de Colón, Panamá.`}
>
  <Navbar />

  <div class={`viewer-page${isStructured ? ' viewer-structured' : ''}`}>

    <!-- ── LOADING OVERLAY ── -->
    <div class="loading-overlay" id="loadingOverlay">
      <div class="loading-inner">
        <img src="/logo.jpeg" alt="Colbateries" class="loading-logo" />
        <p class="loading-cat">{cat.label}</p>
        <div class="progress-track"><div class="progress-fill" id="progressFill"></div></div>
        <p class="progress-pct" id="progressPct">0%</p>
      </div>
    </div>

    <!-- ── TOP BAR ── -->
    <div class="viewer-bar">
      <div class="bar-left">
        <a href="/catalogo" class="breadcrumb">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
          Catálogos
        </a>
        <span class="breadcrumb-sep">/</span>
        <span class="breadcrumb-current">{cat.label}</span>
      </div>

      <div class="bar-nav">
        {prev
          ? <a href={`/catalogo/${prev.slug}`} class="nav-btn" title={prev.label}>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
              <span class="nav-label">Anterior</span>
            </a>
          : <span class="nav-btn disabled"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg></span>
        }
        <span class="nav-pos">{idx + 1} <span class="nav-of">de</span> {groupCats.length}</span>
        {next
          ? <a href={`/catalogo/${next.slug}`} class="nav-btn" title={next.label}>
              <span class="nav-label">Siguiente</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
            </a>
          : <span class="nav-btn disabled"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg></span>
        }
      </div>

      <div class="bar-actions">
        <a href={`/catalogos/${slug}.pdf`} download class="btn-dl">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          Descargar PDF
        </a>
        <a href={`https://wa.me/50764156382?text=${waMsg}`} target="_blank" rel="noopener" class="btn-wa">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Solicitar
        </a>
      </div>
    </div>

    <!-- ══════════════════════════════════════════
         GALLERY MODE (cat.pages defined)
    ══════════════════════════════════════════ -->
    {isGallery && (
      <div class="gallery-viewer" id="galleryViewer">

        <!-- Page counter -->
        <div class="gallery-counter">
          <span id="gallCurrent">1</span>
          <span class="counter-sep">/</span>
          <span>{cat.pages}</span>
          <span class="counter-label">páginas</span>
        </div>

        <!-- Main stage -->
        <div class="gallery-stage">
          <button class="gallery-arrow arrow-prev" id="gallPrev" aria-label="Página anterior">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
          </button>

          <div class="gallery-img-wrap" id="gallImgWrap">
            <img
              id="gallImg"
              src={`/catalogo-pages/${slug}/page-01.jpg`}
              alt="Página 1 del catálogo"
              class="gallery-img"
            />
            <div class="zoom-hint" id="zoomHint">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                <line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/>
              </svg>
              Toca para ampliar
            </div>
          </div>

          <button class="gallery-arrow arrow-next" id="gallNext" aria-label="Página siguiente">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div>

        <!-- Thumbnail strip -->
        <div class="thumb-strip" id="thumbStrip">
          {pageNums.map(n => (
            <button
              class={`thumb-btn${n === 1 ? ' active' : ''}`}
              data-page={n}
              aria-label={`Ir a página ${n}`}
            >
              <img
                src={`/catalogo-pages/${slug}/page-${String(n).padStart(2, '0')}.jpg`}
                alt={`Pág ${n}`}
                loading="lazy"
              />
              <span class="thumb-num">{n}</span>
            </button>
          ))}
        </div>

      </div>
    )}

    <!-- ══════════════════════════════════════════
         STRUCTURED MODE (cat.structured defined)
    ══════════════════════════════════════════ -->
    {isStructured && !isETA && (
      <div class="struct-viewer" id="structViewer">

        <!-- Sticky controls -->
        <div class="struct-controls">
          <div class="struct-search-wrap">
            <svg class="search-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input type="search" id="structSearch" placeholder="Buscar por referencia, medida o color..." autocomplete="off" class="struct-search-input" />
          </div>
          <div class="tipo-bar" id="tipoBar">
            <button class="tipo-pill active" data-tipo="">Todas</button>
            <button class="tipo-pill" data-tipo="CON ROSCA">Con Rosca</button>
            <button class="tipo-pill" data-tipo="CON ROSCA Y TUBO">Rosca y Tubo</button>
            <button class="tipo-pill" data-tipo="ECONÓMICAS">Económicas</button>
          </div>
          <span class="results-label"><span id="resultCount">{products.length}</span> RESULTADOS</span>
        </div>

        <!-- Product grid (populated by JS) -->
        <div class="product-grid" id="productGrid"></div>

        <!-- Empty state -->
        <div class="empty-state" id="emptyState" style="display:none">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" style="color:#444">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
          <p class="empty-msg">Sin resultados</p>
          <button class="empty-reset" id="emptyReset">Ver todas</button>
        </div>

      </div>
    )}

    <!-- ══════════════════════════════════════════
         ETA STRUCTURED MODE
    ══════════════════════════════════════════ -->
    {isETA && (
      <div class="eta-viewer" id="etaViewer">

        <!-- Sticky controls -->
        <div class="eta-controls">
          <div class="eta-search-wrap">
            <svg class="eta-search-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input type="search" id="etaSearch" placeholder="Buscar por modelo, tipo..." autocomplete="off" class="eta-search-input" />
          </div>
          <div class="eta-tipo-bar" id="etaTipoBar">
            <button class="eta-tipo-pill active" data-tipo="">Todos</button>
            <button class="eta-tipo-pill" data-tipo="CRONÓGRAFO">Cronógrafo</button>
            <button class="eta-tipo-pill" data-tipo="CABALLERO">Caballero</button>
            <button class="eta-tipo-pill" data-tipo="DAMA">Dama</button>
          </div>
          <button class="eta-fecha-toggle" id="etaFechaToggle" data-active="false">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            Con Fecha
          </button>
          <span class="eta-results-label"><span id="etaCount">{products.length}</span> MODELOS</span>
        </div>

        <!-- Grid (server-rendered CatalogCard components) -->
        <div class="eta-grid" id="etaGrid">
          {products.map((p: any) => (
            <div
              class="eta-card-wrapper"
              data-tipo={p.tipo}
              data-fecha={String(p.fecha)}
              data-modelo={p.modelo.toLowerCase()}
            >
              <CatalogCard
                imagenSrc={p.img}
                titulo={`ETA ${p.modelo}`}
                detalles={{
                  dimensiones: p.dimensiones,
                  altura: p.altura,
                  joyas: p.joyas,
                  bateria: p.bateria,
                  intercambios: p.intercambios,
                }}
                tipo={p.tipo}
                fecha={p.fecha}
              />
            </div>
          ))}
        </div>

        <!-- Empty state -->
        <div class="eta-empty" id="etaEmpty" style="display:none">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" style="color:#444">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
          <p style="color:#555;font-size:0.9rem;font-weight:600;">Sin resultados</p>
          <button id="etaReset" class="eta-reset-btn">Ver todos</button>
        </div>

      </div>

      <!-- Image modal -->
      <div class="eta-modal" id="etaModal" role="dialog" aria-modal="true" aria-label="Vista ampliada">
        <div class="eta-modal-inner" id="etaModalInner">
          <div class="eta-modal-img-wrap">
            <img class="eta-modal-img" id="etaModalImg" src="" alt="" />
          </div>
          <div class="eta-modal-footer">
            <p class="eta-modal-title" id="etaModalTitle"></p>
            <button class="eta-modal-close" id="etaModalClose">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
              </svg>
              Cerrar
            </button>
          </div>
        </div>
      </div>
    )}

    <!-- ══════════════════════════════════════════
         PDF MODE (no cat.pages)
    ══════════════════════════════════════════ -->
    {!isGallery && !isStructured && (
      <div class="viewer-frame" id="viewerFrame">
        <iframe id="pdfFrame" title={`Catálogo ${cat.label}`} class="pdf-iframe" allowfullscreen></iframe>

        <div class="pdf-cover" id="pdfCover" style="display:none">
          <div class="cover-inner">
            <div class="cover-logo-strip">
              <img src="/logo.jpeg" alt="Colbateries S.A." class="cover-logo-img" />
            </div>
            <div class="cover-divider"></div>
            <div class="cover-text">
              <p class="cover-line cover-line-1">CATÁLOGO</p>
              {line1 !== 'CATÁLOGO' && <p class="cover-line cover-line-2">{line1}</p>}
              {line2 && <p class="cover-line cover-line-3">{line2}</p>}
            </div>
            <div class="cover-footer">
              <a href={`https://wa.me/50764156382?text=${waMsg}`} target="_blank" rel="noopener" class="cover-cta">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                Solicitar este catálogo por WhatsApp
              </a>
              <p class="cover-note">El catálogo se envía en PDF de inmediato</p>
            </div>
          </div>
        </div>
      </div>
    )}

    <!-- ── ZOOM MODAL (gallery only) ── -->
    {isGallery && (
      <div class="zoom-modal" id="zoomModal" aria-modal="true" role="dialog" aria-label="Imagen ampliada">
        <button class="zoom-close" id="zoomClose" aria-label="Cerrar">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
          Cerrar
        </button>
        <div class="zoom-backdrop" id="zoomBackdrop"></div>
        <img id="zoomImg" class="zoom-img" src="" alt="" />
        <div class="zoom-nav">
          <button class="zoom-nav-btn" id="zoomPrev" aria-label="Anterior">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <span class="zoom-page-label"><span id="zoomPageNum">1</span> / {cat.pages}</span>
          <button class="zoom-nav-btn" id="zoomNext" aria-label="Siguiente">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div>
      </div>
    )}

    <!-- ── SIBLING FOOTER ── -->
    <div class="viewer-footer">
      <div class="footer-group">
        <span class="footer-group-label">{cat.group}</span>
        <div class="footer-siblings">
          {groupCats.map(c => (
            <a href={`/catalogo/${c.slug}`} class={`sibling-pill${c.slug === slug ? ' active' : ''}`}>
              {c.label}
            </a>
          ))}
        </div>
      </div>
    </div>

  </div>
</Layout>

<style>
  .viewer-page {
    display: flex;
    flex-direction: column;
    height: 100vh;
    padding-top: 78px;
    background: #161616;
  }

  /* ── LOADING ── */
  .loading-overlay {
    position: fixed; inset: 0; z-index: 300;
    background: #161616;
    display: flex; align-items: center; justify-content: center;
    transition: opacity 0.45s ease;
  }

  .loading-inner {
    display: flex; flex-direction: column;
    align-items: center; gap: 1rem;
    width: min(300px, 80vw);
  }

  .loading-logo {
    height: 50px; width: auto; object-fit: contain;
    filter: brightness(0) invert(1); opacity: 0.9;
    margin-bottom: 0.5rem;
  }

  .loading-cat {
    font-family: var(--font-heading); font-size: 0.95rem;
    font-weight: 700; color: rgba(255,255,255,0.5);
    letter-spacing: 0.04em; text-align: center;
  }

  .progress-track {
    width: 100%; height: 3px;
    background: rgba(255,255,255,0.08); border-radius: 2px; overflow: hidden;
  }

  .progress-fill {
    height: 100%; width: 0%;
    background: var(--yellow); border-radius: 2px;
    transition: width 0.2s ease;
    box-shadow: 0 0 8px rgba(242,169,0,0.5);
  }

  .progress-pct {
    font-size: 0.7rem; font-weight: 700;
    color: rgba(255,255,255,0.3); letter-spacing: 0.06em;
  }

  /* ── TOP BAR ── */
  .viewer-bar {
    display: flex; align-items: center;
    justify-content: space-between; gap: 1rem;
    padding: 0 1.5rem; height: 48px;
    background: #212121; border-bottom: 1px solid #2e2e2e;
    flex-shrink: 0; z-index: 10;
  }

  .bar-left {
    display: flex; align-items: center;
    gap: 0.5rem; min-width: 0; flex: 1;
  }

  .breadcrumb {
    display: inline-flex; align-items: center; gap: 0.3rem;
    font-size: 0.82rem; font-weight: 600; color: #888;
    text-decoration: none; white-space: nowrap; flex-shrink: 0;
    transition: color 0.2s;
  }

  .breadcrumb:hover { color: var(--yellow); }
  .breadcrumb-sep { color: #444; flex-shrink: 0; }

  .breadcrumb-current {
    font-size: 0.82rem; font-weight: 700; color: #ddd;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }

  .bar-nav { display: flex; align-items: center; gap: 0.4rem; flex-shrink: 0; }

  .nav-btn {
    display: inline-flex; align-items: center; gap: 0.3rem;
    padding: 0.3rem 0.65rem;
    background: #2e2e2e; border: 1px solid #3a3a3a; border-radius: 6px;
    color: #aaa; font-size: 0.78rem; font-weight: 600;
    text-decoration: none; white-space: nowrap;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }

  .nav-btn:not(.disabled):hover {
    background: var(--yellow); border-color: var(--yellow); color: #111;
  }

  .nav-btn.disabled { opacity: 0.25; cursor: default; }
  .nav-label { font-size: 0.76rem; }
  .nav-pos { font-size: 0.78rem; font-weight: 600; color: #666; padding: 0 0.4rem; }
  .nav-of { font-weight: 400; }

  .bar-actions { display: flex; align-items: center; gap: 0.5rem; flex-shrink: 0; }

  .btn-dl {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.3rem 0.8rem;
    background: #2e2e2e; border: 1px solid #3a3a3a; border-radius: 6px;
    color: #aaa; font-size: 0.8rem; font-weight: 600;
    text-decoration: none; white-space: nowrap; transition: background 0.2s, color 0.2s;
  }

  .btn-dl:hover { background: #3a3a3a; color: #fff; }

  .btn-wa {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.3rem 1rem;
    background: #25D366; border-radius: 6px;
    color: #fff; font-size: 0.8rem; font-weight: 700;
    text-decoration: none; white-space: nowrap;
    transition: background 0.2s, transform 0.2s;
  }

  .btn-wa:hover { background: #1da851; transform: translateY(-1px); }

  /* ══════════════════════════════
     GALLERY VIEWER
  ══════════════════════════════ */
  .gallery-viewer {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: #161616;
    min-height: 0;
  }

  /* Page counter */
  .gallery-counter {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    padding: 0.5rem 0;
    font-size: 0.9rem;
    font-weight: 700;
    color: #888;
    flex-shrink: 0;
    background: #1a1a1a;
    border-bottom: 1px solid #252525;
  }

  #gallCurrent {
    font-size: 1.1rem;
    font-weight: 900;
    color: var(--yellow);
  }

  .counter-sep { color: #555; }
  .counter-label { font-size: 0.78rem; font-weight: 500; color: #555; margin-left: 0.2rem; }

  /* Stage */
  .gallery-stage {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    min-height: 0;
    position: relative;
  }

  .gallery-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,0.08);
    color: #fff;
    transition: background 0.2s ease, transform 0.2s ease;
    flex-shrink: 0;
  }

  .arrow-prev { left: 1rem; }
  .arrow-next { right: 1rem; }

  .gallery-arrow:hover {
    background: var(--yellow);
    color: #111;
    transform: translateY(-50%) scale(1.08);
  }

  .gallery-arrow:disabled {
    opacity: 0.2;
    cursor: default;
  }

  .gallery-arrow:disabled:hover {
    background: rgba(255,255,255,0.08);
    color: #fff;
    transform: translateY(-50%) scale(1);
  }

  .gallery-img-wrap {
    position: relative;
    max-width: calc(100% - 9rem);
    max-height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: zoom-in;
  }

  .gallery-img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    display: block;
    border-radius: 6px;
    box-shadow: 0 8px 48px rgba(0,0,0,0.6);
    transition: opacity 0.25s ease;
    user-select: none;
  }

  .gallery-img.fading { opacity: 0; }

  .zoom-hint {
    position: absolute;
    bottom: 0.75rem;
    right: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.72rem;
    font-weight: 600;
    color: rgba(255,255,255,0.55);
    background: rgba(0,0,0,0.5);
    padding: 0.3rem 0.6rem;
    border-radius: 6px;
    pointer-events: none;
    opacity: 1;
    transition: opacity 0.3s ease;
  }

  /* Thumbnail strip */
  .thumb-strip {
    display: flex;
    gap: 0.5rem;
    padding: 0.6rem 1rem;
    overflow-x: auto;
    background: #1a1a1a;
    border-top: 1px solid #252525;
    flex-shrink: 0;
    scrollbar-width: thin;
    scrollbar-color: #3a3a3a #1a1a1a;
  }

  .thumb-strip::-webkit-scrollbar { height: 4px; }
  .thumb-strip::-webkit-scrollbar-track { background: #1a1a1a; }
  .thumb-strip::-webkit-scrollbar-thumb { background: #3a3a3a; border-radius: 2px; }

  .thumb-btn {
    flex-shrink: 0;
    width: 90px;
    border: 2px solid transparent;
    border-radius: 6px;
    overflow: hidden;
    cursor: pointer;
    background: #2a2a2a;
    padding: 0;
    position: relative;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .thumb-btn img {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    display: block;
  }

  .thumb-num {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgba(0,0,0,0.65);
    color: rgba(255,255,255,0.7);
    font-size: 0.65rem;
    font-weight: 700;
    text-align: center;
    padding: 0.1rem 0;
  }

  .thumb-btn:hover { border-color: rgba(242,169,0,0.5); transform: translateY(-2px); }

  .thumb-btn.active {
    border-color: var(--yellow);
    box-shadow: 0 0 12px rgba(242,169,0,0.35);
  }

  .thumb-btn.active .thumb-num { background: var(--yellow); color: #111; font-weight: 900; }

  /* ══════════════════════════════
     ZOOM MODAL
  ══════════════════════════════ */
  .zoom-modal {
    position: fixed;
    inset: 0;
    z-index: 500;
    display: none;
    align-items: center;
    justify-content: center;
    flex-direction: column;
  }

  .zoom-modal.open { display: flex; }

  .zoom-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.92);
    cursor: zoom-out;
  }

  .zoom-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1rem;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 8px;
    color: #fff;
    font-size: 0.85rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.2s;
  }

  .zoom-close:hover { background: var(--red); border-color: var(--red); }

  .zoom-img {
    position: relative;
    z-index: 5;
    max-width: 92vw;
    max-height: 82vh;
    object-fit: contain;
    border-radius: 8px;
    box-shadow: 0 20px 80px rgba(0,0,0,0.8);
    display: block;
  }

  .zoom-nav {
    position: relative;
    z-index: 5;
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 1rem;
  }

  .zoom-nav-btn {
    width: 44px; height: 44px;
    border-radius: 50%; border: none;
    background: rgba(255,255,255,0.1);
    color: #fff; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s;
  }

  .zoom-nav-btn:hover { background: var(--yellow); color: #111; }

  .zoom-page-label {
    font-size: 0.9rem;
    font-weight: 700;
    color: rgba(255,255,255,0.7);
    min-width: 60px;
    text-align: center;
  }

  /* ══════════════════════════════
     PDF VIEWER (fallback mode)
  ══════════════════════════════ */
  .viewer-frame {
    flex: 1; overflow: hidden;
    position: relative; background: #1e1e1e;
  }

  .pdf-iframe { width: 100%; height: 100%; border: none; display: block; }

  .pdf-cover {
    position: absolute; inset: 0;
    background: #f0f0f0;
    display: flex; align-items: center; justify-content: center; overflow: auto;
  }

  .cover-inner {
    width: min(700px, 90%);
    background: var(--white);
    aspect-ratio: 8.5 / 11;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    padding: 4rem 3rem;
    box-shadow: 0 8px 40px rgba(0,0,0,0.3);
    text-align: center; gap: 2rem;
  }

  .cover-logo-strip { display: flex; align-items: center; justify-content: center; }
  .cover-logo-img { height: 80px; width: auto; object-fit: contain; }
  .cover-divider { width: 60px; height: 3px; background: var(--yellow); border-radius: 2px; }

  .cover-text { display: flex; flex-direction: column; align-items: center; gap: 0.25rem; }

  .cover-line { font-family: var(--font-heading); font-weight: 900; line-height: 1.05; color: var(--gray-900); }
  .cover-line-1 { font-size: clamp(2rem, 8vw, 4rem); }
  .cover-line-2 { font-size: clamp(1.5rem, 6vw, 3rem); }
  .cover-line-3 { font-size: clamp(1.5rem, 6vw, 3rem); color: var(--blue); }

  .cover-footer { display: flex; flex-direction: column; align-items: center; gap: 0.75rem; margin-top: 1rem; }

  .cover-cta {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.75rem 1.5rem; background: #25D366; color: #fff;
    font-size: 0.875rem; font-weight: 700; border-radius: 8px;
    text-decoration: none; transition: background 0.2s, transform 0.2s;
    box-shadow: 0 4px 16px rgba(37,211,102,0.3);
  }

  .cover-cta:hover { background: #1da851; transform: translateY(-2px); }
  .cover-note { font-size: 0.78rem; color: var(--gray-700); font-weight: 500; }

  /* ── SIBLING FOOTER ── */
  .viewer-footer {
    background: #212121; border-top: 1px solid #2e2e2e;
    padding: 0.5rem 1.5rem; flex-shrink: 0;
  }

  .footer-group { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }

  .footer-group-label {
    font-size: 0.7rem; font-weight: 700; color: #555;
    text-transform: uppercase; letter-spacing: 0.1em; white-space: nowrap;
  }

  .footer-siblings { display: flex; gap: 0.4rem; flex-wrap: wrap; }

  .sibling-pill {
    font-size: 0.72rem; font-weight: 600;
    padding: 0.2rem 0.65rem; border-radius: 20px;
    text-decoration: none; background: #2a2a2a;
    color: #888; border: 1px solid #333;
    transition: background 0.2s, color 0.2s, border-color 0.2s; white-space: nowrap;
  }

  .sibling-pill:hover { background: #3a3a3a; color: #ddd; }

  .sibling-pill.active {
    background: var(--yellow); color: #111;
    border-color: var(--yellow); font-weight: 700;
  }

  /* ══════════════════════════════
     STRUCTURED PRODUCT MODE
  ══════════════════════════════ */

  .viewer-structured {
    height: auto;
    min-height: 100vh;
    background: #111;
  }

  .struct-viewer { display: flex; flex-direction: column; }

  /* ── Controls ── */
  .struct-controls {
    background: #161616;
    border-bottom: 1px solid #2a2a2a;
    padding: 0.85rem 1.5rem;
    display: flex; align-items: center; gap: 0.75rem;
    flex-wrap: wrap;
    position: sticky; top: 78px; z-index: 50;
  }

  .struct-search-wrap {
    position: relative; flex: 1; min-width: 180px;
  }

  .search-icon {
    position: absolute; left: 0.8rem; top: 50%;
    transform: translateY(-50%); color: #555; pointer-events: none;
  }

  .struct-search-input {
    width: 100%;
    padding: 0.6rem 1rem 0.6rem 2.3rem;
    font-size: 0.85rem; font-family: var(--font-body);
    background: #222; border: 1px solid #333; border-radius: 7px;
    color: #ddd; outline: none;
    transition: border-color 0.2s;
  }

  .struct-search-input:focus { border-color: var(--yellow); }
  .struct-search-input::placeholder { color: #555; }

  .tipo-bar { display: flex; gap: 0.35rem; flex-wrap: wrap; }

  .tipo-pill {
    padding: 0.38rem 0.8rem; border-radius: 50px;
    border: 1px solid #333; background: #1e1e1e;
    color: #666; font-size: 0.72rem; font-weight: 700;
    font-family: var(--font-body); cursor: pointer;
    transition: all 0.15s; white-space: nowrap;
  }

  .tipo-pill:hover { border-color: #555; color: #ccc; }

  .tipo-pill.active {
    background: var(--yellow); border-color: var(--yellow); color: #111;
  }

  .results-label {
    font-size: 0.7rem; font-weight: 800; color: #444;
    letter-spacing: 0.08em; white-space: nowrap; margin-left: auto;
  }

  #resultCount { color: var(--yellow); }

  /* ── Grid ── */
  .product-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: #222;
    padding: 1px 0 0;
  }

  /* ── Card ── */
  .prod-card {
    background: #111;
    display: flex; flex-direction: column;
    overflow: hidden;
    transition: background 0.2s;
    cursor: default;
  }

  .prod-card:hover { background: #171717; }

  /* Image */
  .prod-img-wrap {
    background: #fff;
    aspect-ratio: 1 / 1;
    display: flex; align-items: center; justify-content: center;
    position: relative; overflow: hidden;
    padding: 1.5rem;
  }

  .prod-img {
    width: 100%; height: 100%;
    object-fit: contain; display: block;
    transition: transform 0.3s ease;
  }

  .prod-card:hover .prod-img { transform: scale(1.06); }

  .prod-tipo-tag {
    position: absolute; top: 0.55rem; left: 0.55rem;
    font-size: 0.52rem; font-weight: 900;
    text-transform: uppercase; letter-spacing: 0.1em;
    padding: 0.2rem 0.55rem; border-radius: 3px;
    line-height: 1.4;
  }

  /* Body */
  .prod-card-body {
    padding: 1rem 1.1rem 1.25rem;
    flex: 1; display: flex; flex-direction: column; gap: 0.3rem;
    border-top: 1px solid #1e1e1e;
  }

  .prod-ref {
    font-family: var(--font-heading);
    font-size: 1.1rem; font-weight: 900;
    color: #f0f0f0; letter-spacing: -0.02em; line-height: 1.1;
  }

  .prod-medida {
    font-size: 0.8rem; color: #888; font-weight: 600; letter-spacing: 0.01em;
  }

  .prod-rosca { font-size: 0.67rem; color: #444; font-weight: 600; }

  .prod-swatches {
    display: flex; gap: 0.3rem; flex-wrap: wrap; margin-top: 0.3rem;
  }

  .prod-swatch {
    width: 13px; height: 13px; border-radius: 50%;
    border: 1.5px solid rgba(255,255,255,0.1);
    flex-shrink: 0; position: relative; cursor: default;
  }

  .prod-swatch::after {
    content: attr(title);
    position: absolute; bottom: calc(100% + 5px); left: 50%;
    transform: translateX(-50%);
    background: #f0f0f0; color: #111;
    font-size: 0.55rem; font-weight: 800;
    padding: 0.1rem 0.35rem; border-radius: 3px;
    white-space: nowrap; pointer-events: none;
    opacity: 0; transition: opacity 0.12s; z-index: 10;
  }

  .prod-swatch:hover::after { opacity: 1; }

  .prod-notas {
    font-size: 0.63rem; color: #555;
    font-style: italic; margin-top: 0.1rem;
  }

  /* Empty */
  .empty-state {
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 0.85rem; padding: 6rem 2rem; text-align: center;
  }

  .empty-msg { font-size: 0.95rem; font-weight: 600; color: #444; }

  .empty-reset {
    padding: 0.55rem 1.4rem; background: var(--yellow); color: #111;
    border: none; border-radius: 6px;
    font-size: 0.82rem; font-weight: 800;
    font-family: var(--font-body); cursor: pointer;
    transition: opacity 0.18s;
  }

  .empty-reset:hover { opacity: 0.85; }

  /* ── RESPONSIVE (coronas/structured) ── */
  @media (max-width: 1100px) {
    .product-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 768px) {
    .product-grid { grid-template-columns: repeat(2, 1fr); }
    .struct-controls { padding: 0.75rem 1rem; }
  }

  @media (max-width: 640px) {
    .viewer-bar { padding: 0 0.75rem; gap: 0.5rem; }
    .bar-left { display: none; }
    .nav-label { display: none; }
    .gallery-img-wrap { max-width: calc(100% - 7rem); }
    .gallery-arrow { width: 44px; height: 44px; }
    .arrow-prev { left: 0.4rem; }
    .arrow-next { right: 0.4rem; }
    .thumb-btn { width: 72px; }
    .viewer-footer { padding: 0.4rem 0.75rem; }
    .product-grid { grid-template-columns: 1fr 1fr; }
    .prod-card-body { padding: 0.75rem 0.85rem 1rem; }
    .prod-ref { font-size: 0.95rem; }
    .tipo-pill { font-size: 0.68rem; padding: 0.32rem 0.65rem; }
    .results-label { display: none; }
  }

  /* ══════════════════════════════
     ETA STRUCTURED MODE
  ══════════════════════════════ */

  .viewer-page:has(.eta-viewer) {
    height: auto;
    min-height: 100vh;
    background: #f4f6fa;
  }

  .eta-viewer {
    display: flex;
    flex-direction: column;
    background: #f4f6fa;
  }

  /* ── Controls ── */
  .eta-controls {
    background: #fff;
    border-bottom: 1px solid #dce4f0;
    padding: 0.9rem 1.5rem;
    display: flex; align-items: center; gap: 0.75rem;
    flex-wrap: wrap;
    position: sticky; top: 78px; z-index: 50;
    box-shadow: 0 2px 8px rgba(2,69,152,0.06);
  }

  .eta-search-wrap {
    position: relative; flex: 1; min-width: 200px;
  }

  .eta-search-icon {
    position: absolute; left: 0.85rem; top: 50%;
    transform: translateY(-50%); color: #9aabbf; pointer-events: none;
  }

  .eta-search-input {
    width: 100%;
    padding: 0.65rem 1rem 0.65rem 2.4rem;
    font-size: 0.84rem; font-family: 'IBM Plex Mono', monospace;
    background: #f4f6fa; border: 1px solid #dce4f0; border-radius: 6px;
    color: #1a2a4a; outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .eta-search-input:focus { border-color: var(--blue); box-shadow: 0 0 0 3px rgba(2,69,152,0.08); }
  .eta-search-input::placeholder { color: #9aabbf; }

  .eta-tipo-bar { display: flex; gap: 0.35rem; flex-wrap: wrap; }

  .eta-tipo-pill {
    padding: 0.4rem 0.85rem; border-radius: 50px;
    border: 1px solid #dce4f0; background: #f4f6fa;
    color: #6680a0; font-size: 0.71rem; font-weight: 700;
    font-family: var(--font-body); cursor: pointer;
    letter-spacing: 0.04em;
    transition: all 0.15s; white-space: nowrap;
  }

  .eta-tipo-pill:hover { border-color: var(--blue); color: var(--blue); background: #eef2fa; }
  .eta-tipo-pill.active { background: var(--yellow); border-color: var(--yellow); color: #111; }

  .eta-fecha-toggle {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.4rem 0.85rem; border-radius: 50px;
    border: 1px solid #dce4f0; background: #f4f6fa;
    color: #6680a0; font-size: 0.71rem; font-weight: 700;
    font-family: var(--font-body); cursor: pointer;
    letter-spacing: 0.04em; white-space: nowrap;
    transition: all 0.15s;
  }

  .eta-fecha-toggle:hover { border-color: var(--blue); color: var(--blue); background: #eef2fa; }
  .eta-fecha-toggle[data-active="true"] { background: var(--blue); border-color: var(--blue); color: #fff; }

  .eta-results-label {
    font-size: 0.68rem; font-weight: 800; color: #9aabbf;
    letter-spacing: 0.1em; white-space: nowrap; margin-left: auto;
    font-family: 'IBM Plex Mono', monospace;
  }

  #etaCount { color: var(--blue); }

  /* ── Grid ── */
  .eta-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    padding: 1.5rem;
    width: 100%;
    box-sizing: border-box;
  }

  /* ── Card wrapper (grid item) ── */
  .eta-card-wrapper { display: block; min-width: 0; }
  .eta-card-wrapper[hidden] { display: none !important; }

  /* Empty */
  .eta-empty {
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 0.85rem; padding: 6rem 2rem; text-align: center;
  }

  .eta-reset-btn {
    padding: 0.55rem 1.4rem; background: var(--yellow); color: #111;
    border: none; border-radius: 6px; font-size: 0.82rem; font-weight: 800;
    font-family: var(--font-body); cursor: pointer; transition: opacity 0.18s;
  }

  .eta-reset-btn:hover { opacity: 0.85; }

  /* ── ETA Responsive ── */
  @media (max-width: 1024px) { .eta-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px)  { .eta-grid { grid-template-columns: 1fr; gap: 0.75rem; padding: 0.75rem; } .eta-controls { padding: 0.75rem 1rem; } .eta-fecha-toggle span { display: none; } }

  /* ── Image modal ── */
  .eta-modal {
    position: fixed;
    inset: 0;
    z-index: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.85);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.22s ease;
  }

  .eta-modal.open {
    opacity: 1;
    pointer-events: auto;
  }

  .eta-modal-inner {
    position: relative;
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 24px 80px rgba(0,0,0,0.5);
    max-width: min(680px, 92vw);
    width: 100%;
    overflow: hidden;
    transform: scale(0.94);
    transition: transform 0.22s ease;
  }

  .eta-modal.open .eta-modal-inner {
    transform: scale(1);
  }

  .eta-modal-img-wrap {
    background: #f5f7fb;
    display: flex;
    align-items: center;
    justify-content: center;
    height: min(480px, 55vw);
    padding: 2rem;
  }

  .eta-modal-img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    display: block;
  }

  .eta-modal-footer {
    padding: 1.1rem 1.4rem 1.2rem;
    border-top: 1px solid #eef2f8;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .eta-modal-title {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 800;
    color: #024598;
    margin: 0;
  }

  .eta-modal-close {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.45rem 1rem;
    background: #f4f6fa;
    border: 1px solid #dce4f0;
    border-radius: 6px;
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 700;
    color: #444;
    cursor: pointer;
    transition: background 0.15s;
  }

  .eta-modal-close:hover { background: #eef2f8; }
</style>

<script define:vars={{ slug, isGallery, isStructured, isETA, isCoronas, totalPages: cat.pages ?? 0, catLabel: cat.label, products }}>

  // ── LOADING OVERLAY (shared) ──
  const overlay = document.getElementById('loadingOverlay');
  const fill    = document.getElementById('progressFill');
  const pctEl   = document.getElementById('progressPct');

  let prog = 0;
  const phases = [{ t: 30, ms: 300 }, { t: 70, ms: 900 }, { t: 90, ms: 1200 }];
  let pi = 0, from = 0, t0 = Date.now();

  function setP(v) {
    prog = Math.min(v, 99);
    if (fill) fill.style.width = prog + '%';
    if (pctEl) pctEl.textContent = prog + '%';
  }

  function tickP() {
    if (pi >= phases.length) return;
    const { t, ms } = phases[pi];
    const ratio = Math.min((Date.now() - t0) / ms, 1);
    const e = 1 - Math.pow(1 - ratio, 2);
    setP(Math.round(from + (t - from) * e));
    if (ratio < 1) requestAnimationFrame(tickP);
    else { from = t; pi++; t0 = Date.now(); if (pi < phases.length) requestAnimationFrame(tickP); }
  }
  requestAnimationFrame(tickP);

  function hideOverlay() {
    setP(100);
    if (pctEl) pctEl.textContent = '100%';
    setTimeout(() => {
      if (overlay) { overlay.style.opacity = '0'; setTimeout(() => overlay.style.display = 'none', 450); }
    }, 250);
  }

  // ════════════════════════════
  // GALLERY MODE
  // ════════════════════════════
  if (isGallery) {
    let current = 1;
    const img       = document.getElementById('gallImg');
    const counter   = document.getElementById('gallCurrent');
    const prevBtn   = document.getElementById('gallPrev');
    const nextBtn   = document.getElementById('gallNext');
    const thumbStrip = document.getElementById('thumbStrip');
    const zoomModal  = document.getElementById('zoomModal');
    const zoomImg    = document.getElementById('zoomImg');
    const zoomClose  = document.getElementById('zoomClose');
    const zoomBack   = document.getElementById('zoomBackdrop');
    const zoomPrev   = document.getElementById('zoomPrev');
    const zoomNext   = document.getElementById('zoomNext');
    const zoomNum    = document.getElementById('zoomPageNum');
    const zoomHint   = document.getElementById('zoomHint');

    function pageUrl(n) {
      return `/catalogo-pages/${slug}/page-${String(n).padStart(2, '0')}.jpg`;
    }

    function goTo(n) {
      if (n < 1 || n > totalPages) return;
      if (img) {
        img.classList.add('fading');
        setTimeout(() => {
          img.src = pageUrl(n);
          img.alt = `Página ${n} del catálogo`;
          img.onload = () => img.classList.remove('fading');
        }, 200);
      }
      current = n;
      if (counter) counter.textContent = n;
      if (prevBtn) prevBtn.disabled = n === 1;
      if (nextBtn) nextBtn.disabled = n === totalPages;

      // Update thumbnails
      document.querySelectorAll('.thumb-btn').forEach(btn => {
        const active = parseInt(btn.dataset.page) === n;
        btn.classList.toggle('active', active);
        if (active) btn.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
      });
    }

    // Init buttons state
    if (prevBtn) prevBtn.disabled = true;

    // Thumbnails
    document.querySelectorAll('.thumb-btn').forEach(btn => {
      btn.addEventListener('click', () => goTo(parseInt(btn.dataset.page)));
    });

    prevBtn?.addEventListener('click', () => goTo(current - 1));
    nextBtn?.addEventListener('click', () => goTo(current + 1));

    // Keyboard
    document.addEventListener('keydown', (e) => {
      if (zoomModal?.classList.contains('open')) {
        if (e.key === 'ArrowLeft') goToZoom(current - 1);
        else if (e.key === 'ArrowRight') goToZoom(current + 1);
        else if (e.key === 'Escape') closeZoom();
        return;
      }
      if (e.key === 'ArrowLeft') goTo(current - 1);
      else if (e.key === 'ArrowRight') goTo(current + 1);
    });

    // Touch/swipe
    let touchX = 0;
    const stage = document.querySelector('.gallery-stage');
    stage?.addEventListener('touchstart', e => { touchX = e.touches[0].clientX; }, { passive: true });
    stage?.addEventListener('touchend', e => {
      const dx = e.changedTouches[0].clientX - touchX;
      if (Math.abs(dx) > 50) dx < 0 ? goTo(current + 1) : goTo(current - 1);
    });

    // Zoom modal
    function openZoom() {
      if (!zoomModal || !zoomImg) return;
      zoomImg.src = pageUrl(current);
      if (zoomNum) zoomNum.textContent = current;
      zoomModal.classList.add('open');
      if (zoomHint) zoomHint.style.opacity = '0';
    }

    function closeZoom() {
      zoomModal?.classList.remove('open');
    }

    function goToZoom(n) {
      if (n < 1 || n > totalPages) return;
      goTo(n);
      if (zoomImg) zoomImg.src = pageUrl(n);
      if (zoomNum) zoomNum.textContent = n;
    }

    document.querySelector('.gallery-img-wrap')?.addEventListener('click', openZoom);
    zoomClose?.addEventListener('click', closeZoom);
    zoomBack?.addEventListener('click', closeZoom);
    zoomPrev?.addEventListener('click', () => goToZoom(current - 1));
    zoomNext?.addEventListener('click', () => goToZoom(current + 1));

    // First image loads → hide overlay
    if (img) {
      if (img.complete) hideOverlay();
      else img.addEventListener('load', hideOverlay, { once: true });
    }
    setTimeout(hideOverlay, 8000);
  }

  // ════════════════════════════
  // PDF MODE
  // ════════════════════════════
  else if (!isStructured) {
    const frame  = document.getElementById('pdfFrame');
    const cover  = document.getElementById('pdfCover');
    const pdfUrl = `/catalogos/${slug}.pdf`;

    fetch(pdfUrl, { method: 'HEAD' })
      .then(r => {
        if (r.ok) {
          frame.src = `${pdfUrl}#view=FitH&toolbar=0`;
          frame.addEventListener('load', hideOverlay, { once: true });
        } else {
          if (frame) frame.style.display = 'none';
          if (cover) cover.style.display = 'flex';
          hideOverlay();
        }
      })
      .catch(() => {
        if (frame) frame.style.display = 'none';
        if (cover) cover.style.display = 'flex';
        hideOverlay();
      });

    setTimeout(hideOverlay, 12000);
  }

  // ════════════════════════════
  // CORONAS STRUCTURED MODE
  // ════════════════════════════
  if (isCoronas) {
    const SWATCH = {
      'PLATEADA': '#C0C0C8', 'DORADA': '#D4AF37',
      'NEGRA': '#3a3a3a',    'ORO ROSA': '#C88898',
    };
    const TIPO_STYLE = {
      'CON ROSCA':        'background:#f2a900;color:#111',
      'CON ROSCA Y TUBO': 'background:#024598;color:#fff',
      'ECONÓMICAS':       'background:#e64132;color:#fff',
    };
    const TIPO_LABEL = {
      'CON ROSCA': 'Con Rosca',
      'CON ROSCA Y TUBO': 'Rosca y Tubo',
      'ECONÓMICAS': 'Económica',
    };

    function buildCard(p) {
      const safe = p.ref.replace(/\//g, '_');
      const imgSrc = `/coronas-imgs/${safe}.jpg`;
      const colors = p.color.split(', ').map(c => c.trim());
      const swatches = colors.map(c =>
        `<span class="prod-swatch" title="${c}" style="background:${SWATCH[c] ?? '#888'}"></span>`
      ).join('');
      const notas = p.notas ? `<div class="prod-notas">${p.notas}</div>` : '';
      const tipoStyle = TIPO_STYLE[p.tipo] ?? 'background:#444;color:#fff';
      const tipoLabel = TIPO_LABEL[p.tipo] ?? p.tipo;
      return `
        <div class="prod-card">
          <div class="prod-img-wrap">
            <img src="${imgSrc}" alt="Corona ${p.ref}" class="prod-img" loading="lazy" />
            <span class="prod-tipo-tag" style="${tipoStyle}">${tipoLabel}</span>
          </div>
          <div class="prod-card-body">
            <div class="prod-ref">${p.ref}</div>
            <div class="prod-medida">${p.medida.replace(/\s*X\s*/g, ' × ')}</div>
            <div class="prod-rosca">Rosca ${p.rosca}</div>
            <div class="prod-swatches">${swatches}</div>
            ${notas}
          </div>
        </div>
      `;
    }

    const grid       = document.getElementById('productGrid');
    const countEl    = document.getElementById('resultCount');
    const emptyState = document.getElementById('emptyState');
    const emptyReset = document.getElementById('emptyReset');
    const searchEl   = document.getElementById('structSearch');

    let activeTipo = '';
    let searchQ    = '';

    function applyFilters() {
      const q = searchQ.toLowerCase().trim();
      const filtered = products.filter(p => {
        const matchTipo = !activeTipo || p.tipo === activeTipo;
        const matchQ    = !q || p.ref.toLowerCase().includes(q) || p.medida.toLowerCase().includes(q) || p.color.toLowerCase().includes(q);
        return matchTipo && matchQ;
      });

      if (grid) grid.innerHTML = filtered.map(buildCard).join('');
      if (countEl) countEl.textContent = filtered.length;
      if (emptyState) emptyState.style.display = filtered.length === 0 ? 'flex' : 'none';
    }

    // Initial render
    applyFilters();
    hideOverlay();

    // Tipo filters
    document.querySelectorAll('.tipo-pill').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.tipo-pill').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeTipo = btn.dataset.tipo ?? '';
        applyFilters();
      });
    });

    // Search
    searchEl?.addEventListener('input', (e) => {
      searchQ = e.target.value;
      applyFilters();
    });

    // Empty reset
    emptyReset?.addEventListener('click', () => {
      searchQ = '';
      activeTipo = '';
      if (searchEl) searchEl.value = '';
      document.querySelectorAll('.tipo-pill').forEach(b => b.classList.remove('active'));
      document.querySelector('.tipo-pill[data-tipo=""]')?.classList.add('active');
      applyFilters();
    });
  }

  // ════════════════════════════
  // ETA STRUCTURED MODE
  // ════════════════════════════
  if (isETA) {
    const countEl  = document.getElementById('etaCount');
    const emptyEl  = document.getElementById('etaEmpty');
    const searchEl = document.getElementById('etaSearch');
    const tipoBar  = document.getElementById('etaTipoBar');
    const fechaBtn = document.getElementById('etaFechaToggle');
    const resetBtn = document.getElementById('etaReset');

    let activeTipo = '';
    let fechaOnly  = false;
    let searchQ    = '';

    function applyETAFilters() {
      const q = searchQ.toLowerCase().trim();
      let count = 0;
      document.querySelectorAll('.eta-card-wrapper').forEach(wrapper => {
        const tipo   = wrapper.dataset.tipo  ?? '';
        const fecha  = wrapper.dataset.fecha === 'true';
        const modelo = wrapper.dataset.modelo ?? '';
        const show =
          (!activeTipo || tipo === activeTipo) &&
          (!fechaOnly  || fecha) &&
          (!q          || modelo.includes(q) || tipo.toLowerCase().includes(q));
        wrapper.hidden = !show;
        if (show) count++;
      });
      if (countEl) countEl.textContent = count;
      if (emptyEl) emptyEl.style.display = count === 0 ? 'flex' : 'none';
    }

    hideOverlay();

    // ── Image modal ──
    const modal      = document.getElementById('etaModal');
    const modalImg   = document.getElementById('etaModalImg');
    const modalTitle = document.getElementById('etaModalTitle');
    const modalClose = document.getElementById('etaModalClose');

    function openModal(img, title) {
      if (!modal || !modalImg || !modalTitle) return;
      modalImg.src   = img;
      modalImg.alt   = title;
      modalTitle.textContent = title;
      modal.classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modal?.classList.remove('open');
      document.body.style.overflow = '';
    }

    document.getElementById('etaGrid')?.addEventListener('click', e => {
      const card = e.target.closest('[data-img]');
      if (card) openModal(card.dataset.img, card.dataset.title);
    });

    modalClose?.addEventListener('click', closeModal);
    modal?.addEventListener('click', e => { if (e.target === modal) closeModal(); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

    tipoBar?.querySelectorAll('.eta-tipo-pill').forEach(btn => {
      btn.addEventListener('click', () => {
        tipoBar.querySelectorAll('.eta-tipo-pill').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeTipo = btn.dataset.tipo ?? '';
        applyETAFilters();
      });
    });

    fechaBtn?.addEventListener('click', () => {
      fechaOnly = !fechaOnly;
      fechaBtn.dataset.active = fechaOnly ? 'true' : 'false';
      applyETAFilters();
    });

    searchEl?.addEventListener('input', e => {
      searchQ = e.target.value;
      applyETAFilters();
    });

    resetBtn?.addEventListener('click', () => {
      activeTipo = '';
      fechaOnly  = false;
      searchQ    = '';
      if (searchEl) searchEl.value = '';
      tipoBar?.querySelectorAll('.eta-tipo-pill').forEach(b => b.classList.remove('active'));
      tipoBar?.querySelector('.eta-tipo-pill[data-tipo=""]')?.classList.add('active');
      if (fechaBtn) fechaBtn.dataset.active = 'false';
      applyETAFilters();
    });
  }
</script>

---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { groups } from '../../data/catalogs.js';

function waUrl(label) {
  return `https://wa.me/50764156382?text=${encodeURIComponent(`Hola, quisiera solicitar el catálogo de ${label} de Colbateries S.A.`)}`;
}
---

<Layout
  title="Catálogos — Colbateries S.A."
  description="Catálogos especializados de relojes, movimientos, baterías, correas, cristales y herramientas. Más de 1,500 referencias disponibles."
>
  <Navbar />

  <main class="page-main">

    <!-- HERO -->
    <section class="hero">
      <div class="container hero-inner">
        <p class="hero-eyebrow">Zona Libre de Colón · Panamá</p>
        <h1 class="hero-title">Nuestros <span>Catálogos</span></h1>
        <p class="hero-sub">Explore o solicite cualquier catálogo por WhatsApp. Envío inmediato en PDF.</p>
        <div class="hero-stats">
          <div class="hstat">
            <strong>27</strong>
            <span>Catálogos</span>
          </div>
          <div class="hstat-div"></div>
          <div class="hstat">
            <strong>+1,500</strong>
            <span>Referencias</span>
          </div>
          <div class="hstat-div"></div>
          <div class="hstat">
            <strong>PDF</strong>
            <span>Envío inmediato</span>
          </div>
        </div>
      </div>
    </section>

    <!-- SEARCH -->
    <div class="search-wrap">
      <div class="container">
        <div class="search-box">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
          <input
            id="searchInput"
            type="text"
            placeholder="Buscar por nombre — ej: Renata, Miyota, Ronda…"
            autocomplete="off"
          />
          <button id="searchClear" class="clear-btn" aria-label="Limpiar" style="display:none">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </button>
        </div>
        <p class="search-tip" id="searchHint">
          ¿No encuentra lo que busca?
          <a href="https://wa.me/50764156382" target="_blank" rel="noopener">Escríbanos por WhatsApp →</a>
        </p>
      </div>
    </div>

    <!-- STICKY NAV -->
    <div class="group-nav-wrap" id="groupNav">
      <div class="container">
        <nav class="group-nav">
          {groups.map(g => (
            <a href={`#${g.id}`} class="gnav-pill" data-group={g.id}>{g.name}</a>
          ))}
        </nav>
      </div>
    </div>

    <!-- CATALOG GROUPS -->
    <section class="catalog-section">
      <div class="container">

        <div id="emptyState" class="empty-state" style="display:none">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
          <p>Sin resultados para tu búsqueda</p>
          <a href="https://wa.me/50764156382" target="_blank" rel="noopener" class="btn-primary">Consultar por WhatsApp</a>
        </div>

        {groups.map((group, gi) => (
          <div class="group-block" id={group.id} data-group-block={group.id}>

            <!-- Left: content -->
            <div class="group-left">
              <div class="group-intro">
                <span class="group-num">{String(gi + 1).padStart(2, '0')}</span>
                <div>
                  <h2 class="group-name">{group.name}</h2>
                  <p class="group-count">{group.catalogs.length} catálogos disponibles</p>
                </div>
              </div>

              <ul class="cat-list">
                {group.catalogs.map((cat) => (
                  <li class="cat-row" data-label={cat.label.toLowerCase()} data-group={group.id}>
                    <a href={`/catalogo/${cat.slug}`} class="cat-link">
                      <span class="cat-link-name">{cat.label}</span>
                      <svg class="cat-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                        <line x1="5" y1="12" x2="19" y2="12"/>
                        <polyline points="12 5 19 12 12 19"/>
                      </svg>
                    </a>
                  </li>
                ))}
              </ul>

              <a href={waUrl(group.name)} target="_blank" rel="noopener" class="group-wa">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                Solicitar catálogos de {group.name}
              </a>
            </div>

            <!-- Right: image -->
            <div class="group-right">
              <div class="group-img-wrap">
                <img src={group.image} alt={group.name} class="group-img" loading="lazy" />
              </div>
            </div>

          </div>
        ))}

      </div>
    </section>

    <!-- CTA -->
    <section class="cta-strip">
      <div class="container cta-inner">
        <div>
          <h2 class="cta-title">¿Necesita un catálogo completo?</h2>
          <p class="cta-sub">Escríbanos y lo enviamos en PDF de inmediato.</p>
        </div>
        <a href="https://wa.me/50764156382" target="_blank" rel="noopener" class="btn-primary">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Escribir por WhatsApp
        </a>
      </div>
    </section>

  </main>

  <Footer />

  <a href="https://wa.me/50764156382" target="_blank" rel="noopener" class="wa-float" aria-label="WhatsApp">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>
</Layout>

<style>
  .page-main { padding-top: 80px; }

  /* ── HERO ── */
  .hero {
    padding: 4.5rem 0 3.5rem;
    background: var(--white);
    border-bottom: 1px solid var(--gray-200);
    text-align: center;
  }

  .hero-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--blue);
    opacity: 0.45;
    margin-bottom: 1rem;
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(2.2rem, 5vw, 4rem);
    font-weight: 900;
    color: var(--blue);
    letter-spacing: -0.025em;
    line-height: 1.05;
    margin-bottom: 1rem;
  }

  .hero-title span { color: var(--yellow); }

  .hero-sub {
    font-size: 1rem;
    color: var(--gray-700);
    max-width: 420px;
    margin: 0 auto 2.5rem;
    line-height: 1.65;
  }

  .hero-stats {
    display: inline-flex;
    align-items: center;
    gap: 2.5rem;
    padding: 1.1rem 2.5rem;
    background: var(--gray-50);
    border: 1px solid var(--gray-200);
    border-radius: 12px;
  }

  .hstat { text-align: center; }

  .hstat strong {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.7rem;
    font-weight: 900;
    color: var(--yellow);
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 0.2rem;
  }

  .hstat span {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--blue);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 0.5;
  }

  .hstat-div { width: 1px; height: 36px; background: var(--gray-200); }

  /* ── SEARCH ── */
  .search-wrap {
    background: var(--white);
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--gray-200);
  }

  .search-box {
    position: relative;
    display: flex;
    align-items: center;
    max-width: 600px;
    margin: 0 auto;
    border: 1.5px solid var(--gray-200);
    border-radius: 10px;
    background: var(--white);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .search-box:focus-within {
    border-color: var(--yellow);
    box-shadow: 0 0 0 3px rgba(242,169,0,0.1);
  }

  .search-box > svg {
    position: absolute;
    left: 1rem;
    color: var(--gray-700);
    opacity: 0.4;
    pointer-events: none;
  }

  .search-box input {
    width: 100%;
    padding: 0.875rem 3rem;
    border: none;
    outline: none;
    font-family: inherit;
    font-size: 0.95rem;
    color: var(--gray-900);
    background: transparent;
  }

  .search-box input::placeholder { color: var(--gray-700); opacity: 0.4; }

  .clear-btn {
    position: absolute;
    right: 0.75rem;
    background: var(--gray-100);
    border: none;
    cursor: pointer;
    color: var(--gray-700);
    display: flex;
    align-items: center;
    padding: 0.3rem;
    border-radius: 5px;
    transition: background 0.2s, color 0.2s;
  }

  .clear-btn:hover { background: var(--red); color: var(--white); }

  .search-tip {
    text-align: center;
    margin-top: 0.75rem;
    font-size: 0.82rem;
    color: var(--gray-700);
    opacity: 0.6;
  }

  .search-tip a {
    color: var(--blue);
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s;
  }

  .search-tip a:hover { color: var(--yellow); }

  /* ── STICKY NAV ── */
  .group-nav-wrap {
    position: sticky;
    top: 80px;
    z-index: 100;
    background: rgba(255,255,255,0.97);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--gray-200);
    box-shadow: 0 1px 12px rgba(0,0,0,0.05);
  }

  .group-nav {
    display: flex;
    gap: 0.25rem;
    padding: 0.6rem 0;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .group-nav::-webkit-scrollbar { display: none; }

  .gnav-pill {
    flex-shrink: 0;
    padding: 0.4rem 1rem;
    border-radius: 6px;
    font-size: 0.82rem;
    font-weight: 600;
    text-decoration: none;
    color: var(--gray-700);
    transition: background 0.2s, color 0.2s;
    white-space: nowrap;
  }

  .gnav-pill:hover { background: var(--gray-100); color: var(--blue); }
  .gnav-pill.active { background: var(--yellow); color: var(--gray-900); font-weight: 700; }

  /* ── CATALOG SECTION ── */
  .catalog-section {
    padding: 0 0 6rem;
    background: var(--white);
  }

  /* ── GROUP BLOCK — editorial split ── */
  .group-block {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 5rem;
    padding: 5rem 0;
    border-bottom: 1px solid var(--gray-200);
    align-items: start;
  }

  .group-block.hidden { display: none; }

  /* Left column */
  .group-left { display: flex; flex-direction: column; }

  .group-intro {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .group-num {
    font-family: var(--font-heading);
    font-size: 3.5rem;
    font-weight: 900;
    color: rgba(242,169,0,0.18);
    line-height: 1;
    letter-spacing: -0.04em;
    flex-shrink: 0;
    margin-top: 0.1rem;
    user-select: none;
  }

  .group-name {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 900;
    color: var(--blue);
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin-bottom: 0.3rem;
  }

  .group-count {
    font-size: 0.82rem;
    color: var(--gray-700);
    font-weight: 500;
    opacity: 0.6;
  }

  /* Catalog list */
  .cat-list {
    list-style: none;
    border-top: 1px solid var(--gray-200);
    margin-bottom: 2rem;
  }

  .cat-row {
    border-bottom: 1px solid var(--gray-200);
    transition: background 0.15s;
  }

  .cat-row.hidden { display: none; }

  .cat-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.95rem 0.75rem 0.95rem 0;
    text-decoration: none;
    color: var(--blue);
    font-size: 0.97rem;
    font-weight: 600;
    transition: padding-left 0.2s ease, color 0.15s;
    gap: 1rem;
  }

  .cat-link-name { flex: 1; }

  .cat-arrow {
    flex-shrink: 0;
    color: rgba(2,69,152,0.25);
    transition: color 0.2s, transform 0.2s;
  }

  .cat-row:hover { background: rgba(242,169,0,0.04); }

  .cat-row:hover .cat-link {
    padding-left: 0.75rem;
    color: var(--blue);
  }

  .cat-row:hover .cat-arrow {
    color: var(--yellow);
    transform: translateX(3px);
  }

  /* WA button — outlined, clean */
  .group-wa {
    display: inline-flex;
    align-self: flex-start;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.4rem;
    background: transparent;
    border: 1.5px solid #25D366;
    color: #1a9e4e;
    font-size: 0.82rem;
    font-weight: 700;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }

  .group-wa:hover { background: #25D366; color: var(--white); }

  /* Right column — sticky image */
  .group-right {
    position: sticky;
    top: calc(80px + 44px + 2.5rem);
  }

  .group-img-wrap {
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--gray-200);
    box-shadow: 0 8px 32px rgba(0,0,0,0.08);
  }

  .group-img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }

  .group-block:hover .group-img { transform: scale(1.03); }

  /* ── EMPTY STATE ── */
  .empty-state {
    text-align: center;
    padding: 5rem 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    color: var(--gray-700);
  }

  .empty-state p { font-size: 1rem; font-weight: 600; opacity: 0.6; }

  /* ── CTA STRIP ── */
  .cta-strip { background: var(--yellow); padding: 4rem 0; }

  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .cta-title {
    font-family: var(--font-heading);
    font-size: clamp(1.4rem, 2.5vw, 1.9rem);
    font-weight: 900;
    color: var(--blue);
    letter-spacing: -0.02em;
    margin-bottom: 0.3rem;
  }

  .cta-sub { font-size: 0.9rem; color: var(--blue); opacity: 0.65; font-weight: 500; }

  /* ── WA FLOAT ── */
  .wa-float {
    position: fixed;
    bottom: 2rem; right: 2rem;
    width: 54px; height: 54px;
    background: #25D366; color: white;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    z-index: 999;
    box-shadow: 0 4px 20px rgba(37,211,102,0.4);
    transition: transform 0.3s;
    animation: waPulse 3s ease-in-out infinite;
    text-decoration: none;
  }

  .wa-float:hover { transform: scale(1.1); animation: none; }

  @keyframes waPulse {
    0%, 100% { box-shadow: 0 4px 20px rgba(37,211,102,0.4); }
    50%       { box-shadow: 0 4px 30px rgba(37,211,102,0.65); }
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .group-block {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 3.5rem 0;
    }

    .group-right {
      position: static;
      order: -1;
    }

    .group-img-wrap { border-radius: 12px; }

    .group-img { aspect-ratio: 16 / 7; }
  }

  @media (max-width: 640px) {
    .hero-stats {
      flex-direction: column;
      gap: 1rem;
      padding: 1rem 1.75rem;
    }
    .hstat-div { width: 40px; height: 1px; }
    .cta-inner { flex-direction: column; text-align: center; }
    .group-num { font-size: 2.5rem; }
    .group-name { font-size: 1.45rem; }
  }
</style>

<script>
  const input    = document.getElementById('searchInput') as HTMLInputElement | null;
  const clearBtn = document.getElementById('searchClear') as HTMLButtonElement | null;
  const empty    = document.getElementById('emptyState') as HTMLElement | null;
  const blocks   = document.querySelectorAll<HTMLElement>('[data-group-block]');

  function doSearch(q: string) {
    const term = q.toLowerCase().trim();
    if (clearBtn) clearBtn.style.display = term ? 'flex' : 'none';
    let any = false;

    blocks.forEach(block => {
      const rows = block.querySelectorAll<HTMLElement>('.cat-row');
      let hit = false;
      rows.forEach(r => {
        const match = !term || (r.dataset.label ?? '').includes(term);
        r.classList.toggle('hidden', !match);
        if (match) hit = true;
      });
      block.classList.toggle('hidden', !hit);
      if (hit) any = true;
    });

    if (empty) empty.style.display = any ? 'none' : 'flex';
  }

  input?.addEventListener('input', () => doSearch(input.value));
  clearBtn?.addEventListener('click', () => {
    if (input) input.value = '';
    doSearch('');
    input?.focus();
  });

  // Active pill
  const pills = document.querySelectorAll<HTMLElement>('.gnav-pill');

  blocks.forEach(b =>
    new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          const id = (e.target as HTMLElement).dataset.groupBlock;
          pills.forEach(p => p.classList.toggle('active', p.dataset.group === id));
        }
      });
    }, { rootMargin: '-25% 0px -65% 0px' }).observe(b)
  );

  // Smooth scroll
  pills.forEach(pill => {
    pill.addEventListener('click', e => {
      e.preventDefault();
      const t = document.getElementById(pill.dataset.group!);
      if (t) window.scrollTo({ top: t.getBoundingClientRect().top + scrollY - 80 - 44, behavior: 'smooth' });
    });
  });
</script>

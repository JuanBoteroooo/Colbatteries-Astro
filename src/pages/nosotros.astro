---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Nosotros — Colbateries S.A." description="Conozca a Colbateries S.A., su distribuidor de confianza en relojería y accesorios desde la Zona Libre de Colón, Panamá.">
  <Navbar />

  <main class="page-main">
    <!-- Page Hero -->
    <section class="page-hero">
      <div class="container">
        <p class="page-eyebrow">Quiénes somos</p>
        <h1 class="page-title">Conozca <span>Colbateries S.A.</span></h1>
        <p class="page-desc">Distribuidores especializados en relojería, pilas y accesorios desde la Zona Libre de Colón, Panamá.</p>
      </div>
    </section>

    <!-- Historia -->
    <section class="section-white">
      <div class="container two-col">
        <div class="reveal-left">
          <span class="section-tag">Nuestra historia</span>
          <h2 class="section-title">Un socio de confianza en <span>distribución</span></h2>
          <p class="section-desc">
            Colbateries S.A. nació con la visión de ser el enlace más eficiente entre los fabricantes de relojería del mundo y los comercios de América Latina y el Caribe.
          </p>
          <p class="section-desc" style="margin-top:1rem">
            Ubicados estratégicamente en la Zona Libre de Colón — el segundo centro comercial libre más grande del mundo — logramos ofrecer precios de distribuidor con disponibilidad inmediata y sin intermediarios.
          </p>
          <p class="section-desc" style="margin-top:1rem">
            Nuestro equipo conoce el producto a fondo: movimientos, baterías, correas, cristales y herramientas de las marcas más reconocidas a nivel mundial. Trabajamos con distribuidores, tiendas de relojería, joyerías y comercios en toda la región.
          </p>
        </div>
        <div class="about-visual reveal-right">
          <img
            src="https://images.unsplash.com/photo-1509048191080-d2984bad6ae5?w=700&h=520&fit=crop&q=80"
            alt="Relojería profesional"
          />
          <div class="about-badge">
            <span class="badge-num">ZLC</span>
            <span class="badge-txt">Zona Libre de Colón</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Valores -->
    <section class="section-blue">
      <div class="container">
        <div class="section-center reveal">
          <span class="section-tag-light">Nuestros valores</span>
          <h2 class="section-title white">Lo que nos define</h2>
        </div>
        <div class="values-grid">
          {[
            { icon: '🎯', title: 'Especialización', desc: 'Nos enfocamos exclusivamente en relojería y accesorios. Conocemos cada producto que vendemos.' },
            { icon: '📦', title: 'Disponibilidad', desc: 'Más de 1,500 referencias en stock listas para despacho inmediato.' },
            { icon: '🤝', title: 'Confianza', desc: 'Relaciones a largo plazo con nuestros clientes basadas en transparencia y cumplimiento.' },
            { icon: '🌎', title: 'Alcance regional', desc: 'Enviamos a toda Latinoamérica y el Caribe desde nuestra ubicación estratégica en Panamá.' },
          ].map((v, i) => (
            <div class={`value-card reveal delay-${i * 100 + 100}`}>
              <span class="value-icon">{v.icon}</span>
              <h3 class="value-title">{v.title}</h3>
              <p class="value-desc">{v.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="section-white">
      <div class="container stats-row">
        {[
          { num: '+1,500', label: 'Productos en stock' },
          { num: '+20', label: 'Marcas distribuidas' },
          { num: '100%', label: 'Satisfacción garantizada' },
          { num: 'ZLC', label: 'Zona Libre de Colón' },
        ].map((s, i) => (
          <div class={`stat-block reveal delay-${i * 100}`}>
            <span class="stat-num">{s.num}</span>
            <span class="stat-lbl">{s.label}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Ubicación -->
    <section class="section-gray">
      <div class="container two-col reverse">
        <div class="reveal-left">
          <span class="section-tag">Ubicación</span>
          <h2 class="section-title">Encuéntrenos en la <span>Zona Libre</span></h2>
          <p class="section-desc">
            Nos encontramos en el corazón de la Zona Libre de Colón, el hub comercial más importante de las Américas.
          </p>
          <div class="address-card">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <div>
              <p>Manzana 28, Local 8A</p>
              <p>Torre Cofrisa 9</p>
              <p>Zona Libre de Colón, Panamá</p>
            </div>
          </div>
          <div class="contact-pills">
            <a href="https://wa.me/50764156382" target="_blank" rel="noopener" class="pill green">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              +507 6415-6382
            </a>
            <a href="tel:+5074411617" class="pill blue">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.63A2 2 0 012.18 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 8.15a16 16 0 006.29 6.29l1.41-1.41a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
              441-1617
            </a>
          </div>
        </div>
        <div class="reveal-right">
          <img
            src="https://images.unsplash.com/photo-1486325212027-8081e485255e?w=700&h=500&fit=crop&q=80"
            alt="Zona Libre de Colón Panamá"
            class="location-img"
          />
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section-cta">
      <div class="container cta-content">
        <h2 class="cta-title">¿Listo para hacer negocios?</h2>
        <p class="cta-desc">Contáctenos hoy y reciba cotización inmediata para su pedido.</p>
        <div class="cta-btns">
          <a href="https://wa.me/50764156382" target="_blank" rel="noopener" class="btn-primary">
            Escribir por WhatsApp
          </a>
          <a href="/contacto" class="btn-outline-dark">Ver más formas de contacto</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <a href="https://wa.me/50764156382" target="_blank" rel="noopener" class="wa-float" aria-label="WhatsApp">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
  </a>
</Layout>

<style>
  .page-main { padding-top: 80px; }

  .page-hero {
    background: var(--gray-100);
    padding: 5rem 0 4rem;
    text-align: center;
    border-bottom: 1px solid var(--gray-200);
  }

  .page-eyebrow {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 1rem;
  }

  .page-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 900;
    color: var(--blue);
    margin-bottom: 1rem;
    line-height: 1.1;
  }

  .page-title span { color: var(--red); }

  .page-desc {
    font-size: 1.05rem;
    color: var(--gray-700);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .section-white { padding: 6rem 0; background: var(--white); }
  .section-gray { padding: 6rem 0; background: var(--gray-100); }
  .section-blue { padding: 6rem 0; background: var(--gray-100); border-top: 1px solid var(--gray-200); border-bottom: 1px solid var(--gray-200); }

  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .two-col.reverse { direction: rtl; }
  .two-col.reverse > * { direction: ltr; }

  .section-title { margin-bottom: 1.5rem; }
  .section-desc + .section-desc { margin-top: 0; }

  .about-visual {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }

  .about-visual img { width: 100%; height: 400px; object-fit: cover; display: block; }

  .about-badge {
    position: absolute;
    bottom: 1.5rem;
    left: 1.5rem;
    background: var(--blue);
    color: white;
    border-radius: 12px;
    padding: 0.75rem 1.25rem;
    display: flex;
    flex-direction: column;
  }

  .badge-num { font-family: var(--font-heading); font-size: 1.5rem; font-weight: 900; color: var(--yellow); }
  .badge-txt { font-size: 0.75rem; color: rgba(255,255,255,0.7); }

  .section-center { text-align: center; margin-bottom: 3.5rem; }
  .section-tag-light {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 0.75rem;
  }

  .section-title.white { color: var(--blue); }
  .section-title.white span { color: var(--red); }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .value-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: 16px;
    padding: 2rem 1.5rem;
    transition: border-color var(--transition), transform var(--transition), box-shadow var(--transition);
  }

  .value-card:hover {
    border-color: var(--blue);
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

  .value-icon { font-size: 2rem; display: block; margin-bottom: 1rem; }
  .value-title { font-family: var(--font-heading); font-size: 1rem; font-weight: 700; color: var(--blue); margin-bottom: 0.6rem; }
  .value-desc { font-size: 0.85rem; color: var(--gray-700); line-height: 1.65; }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    padding: 3rem 1.5rem;
  }

  .stat-block { text-align: center; }
  .stat-num { display: block; font-family: var(--font-heading); font-size: 2.5rem; font-weight: 900; color: var(--red); line-height: 1; margin-bottom: 0.5rem; }
  .stat-lbl { font-size: 0.875rem; color: var(--gray-700); font-weight: 500; }

  .address-card {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    background: var(--gray-100);
    border-radius: 12px;
    padding: 1.25rem;
    margin: 1.5rem 0;
    color: var(--gray-700);
    font-size: 0.9rem;
    line-height: 1.7;
    border: 1px solid var(--gray-200);
  }

  .address-card svg { flex-shrink: 0; color: var(--blue); margin-top: 3px; }

  .contact-pills { display: flex; gap: 0.75rem; flex-wrap: wrap; }

  .pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1.2rem;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 700;
    transition: opacity var(--transition), transform var(--transition);
    color: white;
  }

  .pill:hover { opacity: 0.88; transform: translateY(-2px); }
  .pill.green { background: #25D366; }
  .pill.blue { background: var(--blue); }

  .location-img { width: 100%; height: 420px; object-fit: cover; border-radius: 20px; box-shadow: var(--shadow-lg); }

  .section-cta {
    background: var(--yellow);
    padding: 5rem 0;
    text-align: center;
  }

  .cta-title {
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    font-weight: 900;
    color: var(--blue);
    margin-bottom: 0.75rem;
  }

  .cta-desc { font-size: 1rem; color: var(--blue-dark); margin-bottom: 2rem; }

  .cta-btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

  .btn-outline-dark {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 2rem;
    border: 2px solid var(--blue);
    color: var(--blue);
    font-weight: 700;
    font-size: 0.95rem;
    border-radius: 6px;
    transition: background var(--transition), color var(--transition);
  }

  .btn-outline-dark:hover {
    background: var(--blue);
    color: var(--white);
  }

  .wa-float {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 58px;
    height: 58px;
    background: #25D366;
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 999;
    box-shadow: 0 4px 20px rgba(37,211,102,0.4);
    transition: transform var(--transition);
  }

  .wa-float:hover { transform: scale(1.1); }

  @media (max-width: 900px) {
    .two-col { grid-template-columns: 1fr; gap: 3rem; }
    .two-col.reverse { direction: ltr; }
    .values-grid { grid-template-columns: repeat(2, 1fr); }
    .stats-row { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 560px) {
    .values-grid { grid-template-columns: 1fr; }
    .stats-row { grid-template-columns: 1fr 1fr; }
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => e.isIntersecting && e.target.classList.add('visible')),
    { threshold: 0.12, rootMargin: '0px 0px -60px 0px' }
  );
  document.querySelectorAll('.reveal, .reveal-left, .reveal-right').forEach(el => observer.observe(el));
</script>
